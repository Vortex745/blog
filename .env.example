SQLITE_DB_PATH="./data/blog.sqlite"

# AI Gateway API 密钥（用于 AI 助手和 RAG 功能）
AI_GATEWAY_API_KEY=""
# AI 对话模型名称
AI_CHAT_MODEL="openai/gpt-4o-mini"
# AI 对话温度 (0-2)
AI_CHAT_TEMPERATURE="0.7"
# Embedding 模型名称
AI_EMBEDDING_MODEL="openai/text-embedding-3-small"
# Embedding 向量维度
AI_EMBEDDING_DIMENSIONS="1536"
# Rerank 模型名称
AI_RERANK_MODEL="cohere/rerank-v3.5"
# 是否启用 AI 清洗 (true/false)
RAG_ENABLE_AI_CLEANING="false"

# LLM API 密钥（用于后台 AI 润色功能）
LLM_API_KEY=""
IMGBB_API_KEY=""
GITHUB_TOKEN=""

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"
