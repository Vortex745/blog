---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { renderMarkdown } from "../../lib/markdown";
import { projectCover as getProjectCover, projectDate, projectTags, readNeonProjects } from "../../lib/neon-content";

const { slug = "" } = Astro.params;

const allProjects = await getCollection("projects");
const project = allProjects.find(
  (p) => p.id.replace(/\.mdx?$/, "") === slug
);
const isLocalProject = !project && slug.startsWith("local-");

if (!project && !isLocalProject) {
  return Astro.redirect("/404");
}

function localSlugToken(value: string): { decoded: string; encoded: string } {
  const encoded = value.slice("local-".length);
  try {
    return { decoded: decodeURIComponent(encoded), encoded };
  } catch {
    return { decoded: encoded, encoded };
  }
}

const neonProjects = isLocalProject ? await readNeonProjects().catch(() => []) : [];
const localToken = isLocalProject ? localSlugToken(slug) : null;
const neonProject = localToken
  ? neonProjects.find((item, index) => {
      const keys = [item.id, item.title, String(index)].map((key) => String(key || "").trim());
      return keys.some((key) => key === localToken.decoded || encodeURIComponent(key) === localToken.encoded);
    })
  : null;

let Content: any = null;
let headings: { depth: number; text: string }[] = [];

if (project) {
  const rendered = await render(project);
  Content = rendered.Content;
  headings = rendered.headings as typeof headings;
}

const tags = project?.data.tags ?? (neonProject ? projectTags(neonProject) : []);
const projectCover = project?.data.coverImage || (neonProject ? getProjectCover(neonProject) : "");
const neonProjectHtml = neonProject
  ? renderMarkdown(neonProject.description || "", { emptyHtml: "<p>暂无项目说明。</p>" })
  : "";
const pageDescription = project?.data.description ?? neonProject?.description ?? "后台本地项目详情";

const relatedProjects = project
  ? allProjects
      .filter(
        (item) =>
          item.id !== project.id &&
          item.data.tags.some((tag: string) => tags.includes(tag))
      )
      .slice(0, 2)
  : [];
const featureHeadings = headings
  .filter((heading) => heading.depth === 2)
  .slice(0, 4);
---

<BaseLayout
  title="子衿的个人博客网站"
  description={pageDescription}
  image={projectCover}
>
  {
    project && Content ? (
      <section class="section-light min-h-[100dvh] px-5 py-16 md:py-24">
        <div class="mx-auto max-w-[1120px]">
          <a
            href="/projects"
            class="link-text mb-8 inline-block text-[var(--color-link-blue)] no-underline hover:underline"
            >← 返回项目列表</a
          >

          <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div>
              {projectCover && (
                <div class="mb-10 overflow-hidden rounded-[30px] border border-black/[0.08] bg-[var(--card)]" data-animate="fade-up">
                  <div class="flex gap-2 border-b border-black/[0.06] px-[18px] py-[14px]">
                    <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                    <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                    <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                  </div>
                  <div class="front-cover front-cover--project-hero">
                    <img
                      src={projectCover}
                      alt={project.data.coverImage ? `${project.data.title} 封面` : ""}
                    />
                  </div>
                </div>
              )}

              <header class="mb-12 max-w-3xl" data-animate="hero">
                <h1 class="display-hero text-[var(--color-near-black)]" data-animate="hero-item">
                  {project.data.title}
                </h1>
                <div class="mb-5 mt-4 flex flex-wrap gap-2" data-animate="hero-item">
                  {tags.map((tag: string) => (
                    <span class="apple-badge">{tag}</span>
                  ))}
                </div>
                <div class="caption-text mt-5 flex flex-wrap gap-x-4 gap-y-2 text-[var(--color-text-secondary)]" data-animate="hero-item">
                  <time>{project.data.date.toLocaleDateString("zh-CN")}</time>
                  <span>{tags.length} 个标签</span>
                </div>
              </header>

              <article class="prose prose-apple max-w-none rounded-[28px] bg-[var(--card)] p-6 md:p-10" data-animate="fade-up">
                <Content />
              </article>
            </div>

            <aside class="space-y-5" data-animate="fade-up">
              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">项目操作</h2>
                <div class="mt-6 flex flex-col gap-3">
                  {project.data.demoUrl && (
                    <a
                      href={project.data.demoUrl}
                      class="btn-primary"
                      target="_blank"
                      rel="noreferrer"
                    >
                      查看 Demo
                    </a>
                  )}
                  {project.data.githubUrl && (
                    <a
                      href={project.data.githubUrl}
                      class="pill-link justify-center"
                      target="_blank"
                      rel="noreferrer"
                    >
                      源代码 ↗
                    </a>
                  )}
                </div>
              </div>

              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">技术栈</h2>
                <div class="mt-5 flex flex-wrap gap-2">
                  {tags.map((tag: string) => (
                    <span class="apple-badge">{tag}</span>
                  ))}
                </div>
              </div>

              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">功能特性</h2>
                <ul class="mt-5 space-y-3">
                  {(featureHeadings.length > 0
                    ? featureHeadings
                    : tags.slice(0, 3).map((tag: string) => ({
                        text: `${tag} 实践`,
                      }))).map((item: { text: string }) => (
                    <li class="caption-text text-[var(--color-text-secondary)]">• {item.text}</li>
                  ))}
                </ul>
              </div>
            </aside>
          </div>

          {relatedProjects.length > 0 && (
            <section class="mt-14" data-animate="fade-up">
              <h2 class="section-heading mb-6 text-[var(--color-near-black)]">相关项目</h2>
              <div class="grid gap-5 md:grid-cols-2" data-animate="stagger">
                {relatedProjects.map((item) => (
                  <a
                    href={`/projects/${item.id.replace(/\.mdx?$/, "")}`}
                    class="apple-card no-underline"
                  >
                    <h3 class="card-title text-[var(--color-near-black)]">{item.data.title}</h3>
                    <p class="caption-text mt-3 text-[var(--color-text-secondary)]">
                      {item.data.description}
                    </p>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </section>
    ) : neonProject ? (
      <section class="section-light min-h-[100dvh] px-5 py-16 md:py-24">
        <div class="mx-auto max-w-[1120px]">
          <a
            href="/projects"
            class="link-text mb-8 inline-block text-[var(--color-link-blue)] no-underline hover:underline"
            >← 返回项目列表</a
          >

          <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div>
              {projectCover && (
                <div class="mb-10 overflow-hidden rounded-[30px] border border-black/[0.08] bg-[var(--card)]" data-animate="fade-up">
                  <div class="flex gap-2 border-b border-black/[0.06] px-[18px] py-[14px]">
                    <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                    <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                    <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                  </div>
                  <div class="front-cover front-cover--project-hero">
                    <img
                      src={projectCover}
                      alt={`${neonProject.title || "项目"} 封面`}
                    />
                  </div>
                </div>
              )}

              <header class="mb-12 max-w-3xl" data-animate="hero">
                <h1 class="display-hero text-[var(--color-near-black)]" data-animate="hero-item">
                  {neonProject.title || "未命名项目"}
                </h1>
                <div class="mb-5 mt-4 flex flex-wrap gap-2" data-animate="hero-item">
                  {tags.map((tag: string) => (
                    <span class="apple-badge">{tag}</span>
                  ))}
                </div>
                <div class="caption-text mt-5 flex flex-wrap gap-x-4 gap-y-2 text-[var(--color-text-secondary)]" data-animate="hero-item">
                  <time>{projectDate(neonProject).toLocaleDateString("zh-CN")}</time>
                  <span>{tags.length} 个标签</span>
                </div>
              </header>

              <article
                class="prose prose-apple max-w-none rounded-[28px] bg-[var(--card)] p-6 md:p-10"
                data-animate="fade-up"
                set:html={neonProjectHtml}
              />
            </div>

            <aside class="space-y-5" data-animate="fade-up">
              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">项目操作</h2>
                <div class="mt-6 flex flex-col gap-3">
                  {neonProject.url && (
                    <a
                      href={neonProject.url}
                      class="btn-primary"
                      target="_blank"
                      rel="noreferrer"
                    >
                      访问项目
                    </a>
                  )}
                </div>
              </div>

              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">技术栈</h2>
                <div class="mt-5 flex flex-wrap gap-2">
                  {tags.map((tag: string) => (
                    <span class="apple-badge">{tag}</span>
                  ))}
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    ) : (
      <section
        class="section-light min-h-[100dvh] px-5 py-16 md:py-24"
        data-local-project-detail
        data-local-slug={slug}
      >
        <div class="mx-auto max-w-[1120px]">
          <a
            href="/projects"
            class="link-text mb-8 inline-block text-[var(--color-link-blue)] no-underline hover:underline"
            >← 返回项目列表</a
          >

          <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div>
              <div class="mb-10 hidden overflow-hidden rounded-[30px] border border-black/[0.08] bg-[var(--card)]" data-animate="fade-up" data-local-cover-wrap>
                <div class="flex gap-2 border-b border-black/[0.06] px-[18px] py-[14px]">
                  <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                  <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                  <span class="h-2.5 w-2.5 rounded-full bg-black/20" />
                </div>
                <div class="front-cover front-cover--project-hero">
                  <img src="" alt="" data-local-cover />
                </div>
              </div>

              <header class="mb-12 max-w-3xl" data-animate="hero">
                <h1 class="display-hero text-[var(--color-near-black)]" data-local-title data-animate="hero-item">
                  正在载入项目...
                </h1>
                <div class="mb-5 mt-4 flex flex-wrap gap-2" data-local-tags data-animate="hero-item"></div>
                <div class="caption-text mt-5 flex flex-wrap gap-x-4 gap-y-2 text-[var(--color-text-secondary)]" data-animate="hero-item">
                  <time data-local-date></time>
                  <span data-local-tag-count></span>
                </div>
              </header>

              <article
                class="prose prose-apple max-w-none rounded-[28px] bg-[var(--card)] p-6 md:p-10"
                data-local-body
                data-animate="fade-up"
              >
                <p>正在载入项目说明...</p>
              </article>
            </div>

            <aside class="space-y-5" data-animate="fade-up">
              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">项目操作</h2>
                <div class="mt-6 flex flex-col gap-3">
                  <a
                    href="#"
                    class="btn-primary"
                    target="_blank"
                    rel="noreferrer"
                    data-local-project-url
                    hidden
                  >
                    访问项目
                  </a>
                </div>
              </div>

              <div class="apple-card">
                <h2 class="card-title text-[var(--color-near-black)]">技术栈</h2>
                <div class="mt-5 flex flex-wrap gap-2" data-local-sidebar-tags></div>
              </div>
            </aside>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<script>
  import { initLocalProjectDetail } from "../../scripts/local-detail";

  initLocalProjectDetail();
  document.addEventListener("astro:after-swap", initLocalProjectDetail);
</script>
