---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { COVER_IMAGE_PLACEHOLDER } from "../../lib/placeholder-images";

const projects = await getCollection("projects");

const sortedProjects = projects.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const allTags = [...new Set(sortedProjects.flatMap((p) => p.data.tags))];
const COVER_PLACEHOLDER = COVER_IMAGE_PLACEHOLDER;

const formatDate = (date: Date) =>
  new Date(date).toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<BaseLayout title="子衿的个人博客网站" description="开源作品与个人实践项目展示。">
  <section class="projects-hero" data-animate="hero">
    <div class="editorial-container">
      <h1 class="projects-title" data-animate="hero-item">项目</h1>
      <p class="projects-subtitle" data-animate="hero-item">开源作品与个人实践</p>
      <div class="projects-stats" data-animate="hero-item">
        <span class="projects-stat">{sortedProjects.length} 个项目</span>
        <span class="projects-stat-sep">·</span>
        <span class="projects-stat">{allTags.length} 个技术标签</span>
      </div>
    </div>
  </section>

  <section class="projects-content">
    <div class="editorial-container">
      {/* Tag Filters */}
      <div class="filter-bar" data-animate="fade-up" id="tag-filters">
        <button class="filter-chip active" data-tag="all">全部</button>
        {allTags.map((tag) => (
          <button class="filter-chip" data-tag={tag}>{tag}</button>
        ))}
      </div>

      {/* Dense Project Grid */}
      {sortedProjects.length > 0 ? (
        <div class="projects-dense-grid" data-animate="stagger" id="projects-list">
          {sortedProjects.map((project, idx) => (
            <div class="project-item" data-tags={JSON.stringify(project.data.tags)}>
              <a href={`/projects/${project.id.replace(/\.mdx?$/, "")}`} class="project-card">
                <div class="front-cover front-cover--card">
                  <img
                    src={project.data.coverImage || COVER_PLACEHOLDER}
                    alt={project.data.coverImage ? `${project.data.title} 封面` : ""}
                    loading="lazy"
                  />
                </div>
                <div class="project-card-header">
                  <div class="project-card-num">{String(idx + 1).padStart(2, "0")}</div>
                  <div class="project-card-meta">
                    <span class="project-card-date">{formatDate(project.data.date)}</span>
                    <div class="project-card-tags">
                      {project.data.tags.slice(0, 3).map((tag) => (
                        <span class="project-card-tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
                <h3 class="project-card-title">{project.data.title}</h3>
                <p class="project-card-desc">{project.data.description}</p>
              </a>
              <div class="project-card-links">
                {project.data.githubUrl && (
                  <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                    GitHub
                  </a>
                )}
                {project.data.demoUrl && (
                  <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer" class="project-link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    演示
                  </a>
                )}
                <a href={`/projects/${project.id.replace(/\.mdx?$/, "")}`} class="project-link project-link-primary">
                  详情
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="empty-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="empty-icon"><path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Z"/><path d="M16 3v4"/><path d="M8 3v4"/><path d="M2 11h20"/></svg>
          <p class="empty-title">暂无项目</p>
          <p class="empty-desc">还没有添加任何项目，请在后台添加内容。</p>
        </div>
      )}

      {/* Empty State */}
      <div id="empty-state" class="empty-state hidden">
        <p>该标签下暂无项目。</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filters = document.querySelectorAll(".filter-chip");
  const items = document.querySelectorAll(".project-item");
  const empty = document.getElementById("empty-state");
  let currentTag = "all";

  function getFilteredItems() {
    return Array.from(items).filter((item) => {
      if (currentTag === "all") return true;
      const tags = JSON.parse(item.dataset.tags || "[]");
      return tags.includes(currentTag);
    });
  }

  function setActiveFilter() {
    filters.forEach((filter) => {
      const active = filter.dataset.tag === currentTag;
      filter.classList.toggle("active", active);
    });
  }

  function render() {
    const filtered = getFilteredItems();
    items.forEach((item) => item.classList.add("hidden"));
    filtered.forEach((item, idx) => {
      item.classList.remove("hidden");
      const numEl = item.querySelector(".project-card-num");
      if (numEl) numEl.textContent = String(idx + 1).padStart(2, "0");
    });
    empty?.classList.toggle("hidden", filtered.length > 0);
    setActiveFilter();
  }

  filters.forEach((filter) => {
    filter.addEventListener("click", () => {
      currentTag = filter.dataset.tag || "all";
      render();
    });
  });

  render();
</script>

<style>
  .editorial-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .projects-hero {
    padding: 48px 0 24px;
  }

  .projects-title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #181c23;
    margin: 0 0 8px;
  }

  .projects-subtitle {
    font-size: 15px;
    color: #717785;
    margin: 0 0 12px;
  }

  .projects-stats {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .projects-stat {
    font-size: 13px;
    color: #a0a8b8;
  }

  .projects-stat-sep {
    color: #c1c6d6;
  }

  /* Content */
  .projects-content {
    padding-bottom: 48px;
  }

  /* Filter Bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(193,198,214,0.3);
  }

  .filter-chip {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 9999px;
    border: 1px solid transparent;
    background: rgba(236,237,247,0.6);
    color: #414753;
    cursor: pointer;
    transition: all 0.15s ease;
    white-space: nowrap;
  }

  .filter-chip:hover {
    background: rgba(224,226,236,0.8);
    color: #181c23;
  }

  .filter-chip.active {
    background: #0059b5;
    color: #fff;
    border-color: #0059b5;
  }

  /* Dense Project Grid */
  .projects-dense-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }

  @media (min-width: 768px) {
    .projects-dense-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .project-item {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid rgba(193,198,214,0.3);
    border-radius: 12px;
    overflow: hidden;
    transition: all 0.15s ease;
  }

  .project-item:hover {
    border-color: rgba(193,198,214,0.6);
    box-shadow: 0 4px 16px rgba(0,0,0,0.05);
    transform: translateY(-1px);
  }

  .project-item.hidden {
    display: none;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    text-decoration: none;
    flex: 1;
  }

  .project-card-header {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .project-card-num {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: #a0a8b8;
    min-width: 28px;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .project-card-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .project-card-date {
    font-size: 12px;
    color: #a0a8b8;
  }

  .project-card-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .project-card-tag {
    font-size: 11px;
    font-weight: 500;
    color: #0059b5;
    background: rgba(0,89,181,0.08);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    color: #181c23;
    margin: 0;
  }

  .project-card:hover .project-card-title {
    color: #0059b5;
  }

  .project-card-desc {
    font-size: 13px;
    line-height: 1.5;
    color: #717785;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Project Links */
  .project-card-links {
    display: flex;
    gap: 8px;
    padding: 0 16px 16px;
    border-top: 1px solid rgba(193,198,214,0.15);
    margin-top: auto;
    padding-top: 12px;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 500;
    color: #717785;
    text-decoration: none;
    padding: 4px 10px;
    border-radius: 6px;
    background: #f4f6fa;
    transition: all 0.15s ease;
  }

  .project-link:hover {
    background: #e8ebf0;
    color: #181c23;
  }

  .project-link-primary {
    color: #0059b5;
    background: rgba(0,89,181,0.08);
    margin-left: auto;
  }

  .project-link-primary:hover {
    background: rgba(0,89,181,0.15);
    color: #0059b5;
  }

  /* Empty State */
  .empty-state {
    text-align: center;
    padding: 48px 0;
    color: #a0a8b8;
    font-size: 14px;
  }

  .empty-state.hidden {
    display: none;
  }

  /* Empty Placeholder */
  .empty-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 24px;
    text-align: center;
    border: 2px dashed rgba(193,198,214,0.4);
    border-radius: 16px;
    background: rgba(244,246,250,0.4);
  }
  .empty-icon {
    color: #c1c6d6;
    margin-bottom: 16px;
  }
  .empty-placeholder .empty-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: #181c23;
    margin: 0 0 8px;
  }
  .empty-placeholder .empty-desc {
    font-size: 14px;
    color: #717785;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .editorial-container {
      padding: 0 16px;
    }

    .projects-hero {
      padding: 32px 0 16px;
    }

    .projects-title {
      font-size: 28px;
    }

    .project-card-header {
      gap: 10px;
    }

    .project-card-num {
      font-size: 12px;
      min-width: 24px;
    }
  }
</style>
