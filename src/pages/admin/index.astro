---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="管理后台" current="dashboard">
  <div class="admin-dashboard">
    <h1 class="admin-page-title">欢迎回来</h1>
    <p class="admin-page-desc">选择左侧菜单开始管理您的网站内容。</p>

    <div class="admin-cards">
      <a href="/admin/home" class="admin-card">
        <div class="admin-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div class="admin-card-body">
          <h3>首页管理</h3>
          <p>编辑前言、引言等首页内容</p>
        </div>
      </a>
      <a href="/admin/projects" class="admin-card">
        <div class="admin-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
        </div>
        <div class="admin-card-body">
          <h3>项目管理</h3>
          <p>添加、编辑和发布项目</p>
        </div>
      </a>
      <a href="/admin/articles" class="admin-card">
        <div class="admin-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
        </div>
        <div class="admin-card-body">
          <h3>文章管理</h3>
          <p>撰写、编辑和发布文章</p>
        </div>
      </a>
      <a href="/admin/gallery" class="admin-card">
        <div class="admin-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
        </div>
        <div class="admin-card-body">
          <h3>图库管理</h3>
          <p>上传和管理图片资源</p>
        </div>
      </a>
      <a href="/admin/about" class="admin-card">
        <div class="admin-card-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </div>
        <div class="admin-card-body">
          <h3>关于管理</h3>
          <p>编辑个人简介和联系信息</p>
        </div>
      </a>
    </div>
  </div>
</AdminLayout>

<style>
  .admin-dashboard {
    max-width: 960px;
  }
  .admin-page-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: #181c23;
    margin-bottom: 8px;
  }
  .admin-page-desc {
    font-size: 15px;
    color: #717785;
    margin-bottom: 32px;
  }
  .admin-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }
  .admin-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 20px;
    border-radius: 16px;
    background: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.6);
    backdrop-filter: blur(24px);
    text-decoration: none;
    transition: background-color 0.2s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.2s cubic-bezier(0.23, 1, 0.32, 1), transform 0.15s cubic-bezier(0.23, 1, 0.32, 1);
    transform: scale(1) translateY(0);
    will-change: transform;
  }
  .admin-card:hover {
    background: rgba(255,255,255,0.9);
    box-shadow: 0 8px 32px rgba(0,0,0,0.06);
    transform: translateY(-2px);
  }
  .admin-card:active {
    transform: scale(0.98) translateY(0);
  }
  .admin-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: rgba(0,89,181,0.08);
    color: #0059b5;
    flex-shrink: 0;
  }
  .admin-card-body h3 {
    font-size: 15px;
    font-weight: 600;
    color: #181c23;
    margin-bottom: 4px;
  }
  .admin-card-body p {
    font-size: 13px;
    color: #717785;
    line-height: 1.4;
  }
</style>
