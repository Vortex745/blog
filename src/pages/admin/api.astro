---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="API 管理" current="api">
  <div class="admin-page-header">
    <h1 class="admin-page-title">API 管理</h1>
    <p class="admin-page-desc">配置 LLM API 连接信息，用于文章和关于页面的 AI 润色功能。</p>
  </div>

  <!-- LLM API Settings -->
  <section class="form-section">
    <div class="section-header">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/><circle cx="12" cy="15" r="1"/></svg>
      <h2 class="section-title">LLM API 设置</h2>
      <span class="section-badge" id="llm-status-badge">未配置</span>
    </div>
    <div class="llm-fields">
      <div class="field-group">
        <label for="llm-base-url" class="field-label">Base URL</label>
        <input id="llm-base-url" type="url" class="field-input" placeholder="https://api.openai.com/v1" />
        <span class="field-hint">OpenAI 兼容协议地址，如 https://api.openai.com/v1 或自定义代理地址</span>
      </div>
      <div class="field-group">
        <label for="llm-api-key" class="field-label">API Key</label>
        <div class="api-key-wrap">
          <input id="llm-api-key" type="password" class="field-input" placeholder="sk-..." />
          <button type="button" id="btn-toggle-key" class="btn-icon btn-toggle-key" title="显示/隐藏密钥">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
        </div>
        <span class="field-hint">API 密钥仅保存在浏览器本地，不会上传到服务器</span>
      </div>
      <div class="field-group">
        <label for="llm-model" class="field-label">模型名称</label>
        <div class="model-input-wrap">
          <input id="llm-model" type="text" class="field-input" placeholder="gpt-4o-mini" list="llm-model-list" />
          <datalist id="llm-model-list">
            <option value="gpt-4o-mini">
            <option value="gpt-4o">
            <option value="gpt-4-turbo">
            <option value="gpt-3.5-turbo">
            <option value="claude-3-5-sonnet-20241022">
            <option value="deepseek-chat">
            <option value="glm-4-flash">
          </datalist>
          <button type="button" id="btn-fetch-models" class="btn-secondary btn-small" title="从 API 获取可用模型列表">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9m-9 9a9 9 0 0 1 9-9"/></svg>
            获取模型
          </button>
        </div>
        <span class="field-hint">输入模型名称或点击"获取模型"从 API 自动识别可用模型</span>
      </div>
      <div class="llm-actions">
        <button type="button" id="btn-save-llm" class="btn-primary btn-small">保存设置</button>
        <button type="button" id="btn-test-llm" class="btn-secondary btn-small">测试连接</button>
        <span id="llm-test-status" class="save-status"></span>
      </div>
    </div>
  </section>

  <!-- Usage Info -->
  <section class="form-section">
    <div class="section-header">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      <h2 class="section-title">使用说明</h2>
    </div>
    <div class="usage-info">
      <p>配置 LLM API 后，以下功能将可用：</p>
      <ul>
        <li><strong>文章管理</strong> — 编辑文章时，工具栏中的 ✨ 按钮可对文章内容进行 AI 润色</li>
        <li><strong>项目管理</strong> — 编辑项目时，可对项目介绍进行 AI 润色</li>
        <li><strong>首页管理</strong> — 根据修改方向生成每日前言和引言</li>
        <li><strong>关于管理</strong> — 编辑理念内容时，可对正文进行 AI 润色</li>
      </ul>
      <p class="usage-note">支持所有 OpenAI 兼容协议的 API 服务，包括 OpenAI、DeepSeek、智谱 (GLM) 等。</p>
    </div>
  </section>
</AdminLayout>

<script>
  import { requestLlmChat } from "../../scripts/admin-llm";

  const LLM_KEY = "admin-llm-settings";
  const llmBaseUrl = document.getElementById("llm-base-url");
  const llmApiKey = document.getElementById("llm-api-key");
  const llmModel = document.getElementById("llm-model");
  const llmModelList = document.getElementById("llm-model-list");
  const btnToggleKey = document.getElementById("btn-toggle-key");
  const btnSaveLlm = document.getElementById("btn-save-llm");
  const btnTestLlm = document.getElementById("btn-test-llm");
  const llmTestStatus = document.getElementById("llm-test-status");
  const btnFetchModels = document.getElementById("btn-fetch-models");
  const llmBadge = document.getElementById("llm-status-badge");

  function loadLlmSettings() {
    try {
      const raw = localStorage.getItem(LLM_KEY);
      if (raw) {
        const s = JSON.parse(raw);
        if (llmBaseUrl) llmBaseUrl.value = s.baseUrl || "";
        if (llmApiKey) llmApiKey.value = s.apiKey || "";
        if (llmModel) llmModel.value = s.model || "";
        updateLlmBadge(s);
      }
    } catch {}
  }

  function saveLlmSettings() {
    const s = {
      baseUrl: llmBaseUrl?.value?.trim() || "",
      apiKey: llmApiKey?.value?.trim() || "",
      model: llmModel?.value?.trim() || "",
    };
    localStorage.setItem(LLM_KEY, JSON.stringify(s));
    updateLlmBadge(s);
  }

  function updateLlmBadge(s) {
    if (!llmBadge) return;
    if (s.baseUrl && s.apiKey && s.model) {
      llmBadge.textContent = "已配置";
      llmBadge.className = "section-badge is-ok";
    } else {
      llmBadge.textContent = "未配置";
      llmBadge.className = "section-badge";
    }
  }

  function getLlmSettings() {
    try {
      const raw = localStorage.getItem(LLM_KEY);
      if (raw) return JSON.parse(raw);
    } catch {}
    return null;
  }

  btnToggleKey?.addEventListener("click", () => {
    if (!llmApiKey) return;
    const isPassword = llmApiKey.type === "password";
    llmApiKey.type = isPassword ? "text" : "password";
  });

  btnSaveLlm?.addEventListener("click", () => {
    saveLlmSettings();
    if (llmTestStatus) {
      llmTestStatus.textContent = "设置已保存";
      llmTestStatus.className = "save-status is-success";
      setTimeout(() => { llmTestStatus.textContent = ""; llmTestStatus.className = "save-status"; }, 2000);
    }
  });

  btnTestLlm?.addEventListener("click", async () => {
    const s = getLlmSettings();
    if (!s || !s.baseUrl || !s.apiKey || !s.model) {
      if (llmTestStatus) {
        llmTestStatus.textContent = "请先填写并保存设置";
        llmTestStatus.className = "save-status is-error";
      }
      return;
    }
    if (llmTestStatus) {
      llmTestStatus.textContent = "正在测试连接...";
      llmTestStatus.className = "save-status is-info";
    }
    try {
      const reply = await requestLlmChat({
        messages: [{ role: "user", content: "Hello, reply with OK only." }],
        maxTokens: 5,
      });
      if (llmTestStatus) {
        llmTestStatus.textContent = `连接成功: ${reply.trim().substring(0, 50)}`;
        llmTestStatus.className = "save-status is-success";
      }
    } catch (err) {
      if (llmTestStatus) {
        llmTestStatus.textContent = "连接失败: " + (err instanceof Error ? err.message : String(err));
        llmTestStatus.className = "save-status is-error";
      }
    }
  });

  btnFetchModels?.addEventListener("click", async () => {
    const baseUrl = llmBaseUrl?.value?.trim();
    const apiKey = llmApiKey?.value?.trim();
    if (!baseUrl || !apiKey) {
      if (llmTestStatus) {
        llmTestStatus.textContent = "请先填写 Base URL 和 API Key";
        llmTestStatus.className = "save-status is-error";
      }
      return;
    }
    if (btnFetchModels) btnFetchModels.disabled = true;
    try {
      const url = baseUrl.replace(/\/+$/, "") + "/models";
      const res = await fetch(url, {
        headers: { "Authorization": "Bearer " + apiKey },
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const models = data.data || [];
      if (llmModelList) llmModelList.innerHTML = "";
      models.forEach(m => {
        const opt = document.createElement("option");
        opt.value = m.id;
        if (llmModelList) llmModelList.appendChild(opt);
      });
      if (models.length > 0 && llmModel && !llmModel.value) {
        llmModel.value = models[0].id;
      }
      if (llmTestStatus) {
        llmTestStatus.textContent = `获取到 ${models.length} 个模型`;
        llmTestStatus.className = "save-status is-success";
        setTimeout(() => { llmTestStatus.textContent = ""; llmTestStatus.className = "save-status"; }, 3000);
      }
    } catch (err) {
      if (llmTestStatus) {
        llmTestStatus.textContent = "获取模型失败: " + (err instanceof Error ? err.message : String(err));
        llmTestStatus.className = "save-status is-error";
      }
    } finally {
      if (btnFetchModels) btnFetchModels.disabled = false;
    }
  });

  loadLlmSettings();
</script>

<style>
  .admin-page-header {
    margin-bottom: 24px;
  }
  .admin-page-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: #181c23;
    margin-bottom: 6px;
  }
  .admin-page-desc {
    font-size: 15px;
    color: #717785;
  }
  .form-section {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.03);
    margin-bottom: 24px;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }
  .section-header svg {
    color: #717785;
    flex-shrink: 0;
  }
  .section-title {
    font-size: 18px;
    font-weight: 600;
    color: #181c23;
    margin: 0;
  }
  .section-badge {
    padding: 3px 10px;
    border-radius: 8px;
    background: rgba(0,89,181,0.08);
    color: #717785;
    font-size: 12px;
    font-weight: 500;
    margin-left: auto;
  }
  .section-badge.is-ok {
    background: rgba(5, 150, 105, 0.1);
    color: #059669;
  }
  .llm-fields {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field-label {
    font-size: 14px;
    font-weight: 500;
    color: #181c23;
  }
  .field-input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(193,198,214,0.5);
    background: rgba(255,255,255,0.7);
    font-family: var(--font-body);
    font-size: 15px;
    color: #181c23;
    outline: none;
    transition: border-color 0.2s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.2s cubic-bezier(0.23, 1, 0.32, 1), transform 0.12s cubic-bezier(0.23, 1, 0.32, 1);
    box-sizing: border-box;
    transform: scale(1);
  }
  .field-input:active {
    transform: scale(0.995);
  }
  .field-input:focus {
    border-color: #0059b5;
    box-shadow: 0 0 0 3px rgba(0,89,181,0.1);
  }
  .field-hint {
    font-size: 12px;
    color: #717785;
  }
  .api-key-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .api-key-wrap .field-input {
    padding-right: 42px;
  }
  .btn-toggle-key {
    position: absolute;
    right: 4px;
    top: 50%;
    transform: translateY(-50%);
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    color: #a0a8b8;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .btn-toggle-key:hover {
    color: #414753;
  }
  .model-input-wrap {
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .model-input-wrap .field-input {
    flex: 1;
  }
  .llm-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 12px;
    border: none;
    background: #0059b5;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.15s ease;
  }
  .btn-primary:hover {
    background: #004a94;
  }
  .btn-primary:active {
    transform: scale(0.97);
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: rgba(255,255,255,0.6);
    color: #414753;
    border: 1px solid rgba(193,198,214,0.5);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .btn-secondary:hover {
    background: rgba(255,255,255,0.9);
    border-color: rgba(113,119,133,0.4);
    color: #181c23;
  }
  .btn-small {
    padding: 6px 12px;
    font-size: 13px;
    min-height: 32px;
  }
  .btn-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: #717785;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s ease;
  }
  .btn-icon:hover {
    background: rgba(0,89,181,0.08);
    color: #0059b5;
  }
  .save-status {
    font-size: 13px;
    font-weight: 500;
    min-height: 20px;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .save-status.is-success { color: #059669; }
  .save-status.is-error { color: #dc2626; }
  .save-status.is-info { color: #0059b5; }

  /* Usage Info */
  .usage-info {
    font-size: 14px;
    color: #414753;
    line-height: 1.7;
  }
  .usage-info p {
    margin: 0 0 8px;
  }
  .usage-info ul {
    margin: 0 0 12px;
    padding-left: 20px;
  }
  .usage-info li {
    margin-bottom: 4px;
  }
  .usage-note {
    font-size: 13px;
    color: #717785;
    padding: 12px 16px;
    border-radius: 10px;
    background: rgba(244,246,250,0.6);
    border: 1px solid rgba(193,198,214,0.3);
  }
</style>
