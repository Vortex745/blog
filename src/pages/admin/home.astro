---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="首页管理" current="home">
  <div class="admin-page-header">
    <h1 class="admin-page-title">首页管理</h1>
    <p class="admin-page-desc">引导 AI 为首页自动生成每日前言和引言。</p>
  </div>

  <form id="home-form" class="admin-form">
    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">生成方向</h2>
        <span id="daily-badge" class="section-badge">今日未生成</span>
      </div>
      <p class="section-desc">后台不再手动添加前言和引言，只填写当天想要的表达方向，再由 AI 生成内容。</p>

      <div class="field-group">
        <label for="generation-guidance" class="field-label">修改方向</label>
        <textarea
          id="generation-guidance"
          name="guidance"
          class="field-input field-textarea"
          rows="4"
          placeholder="例如：今天更偏技术复盘，语气克制一点，强调设计与工程的连接。"
        ></textarea>
        <span class="field-hint">留空也可以生成，填写后会影响标题、描述和引言的语气与主题。</span>
      </div>

      <div class="form-actions">
        <button type="button" id="btn-generate-daily" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          生成今日内容
        </button>
        <button type="submit" class="btn-secondary">保存结果</button>
        <button type="button" id="btn-reset" class="btn-secondary">清除今日结果</button>
        <span id="save-status" class="save-status"></span>
      </div>
    </section>

    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">今日生成结果</h2>
        <span id="generated-date" class="section-badge">未保存</span>
      </div>

      <div class="preview-grid">
        <div class="preview-box">
          <span class="preview-label">前言</span>
          <div class="preview-hero">
            <h3 id="preview-title" class="preview-title">等待生成</h3>
            <p id="preview-lead" class="preview-lead">填写方向后生成今日首页前言。</p>
          </div>
        </div>

        <div class="preview-box">
          <span class="preview-label">引言</span>
          <div class="preview-quote">
            <span class="preview-quote-tag">引言</span>
            <blockquote id="preview-quote-text" class="preview-quote-body">等待生成</blockquote>
            <div class="preview-quote-author">
              <span class="preview-quote-line"></span>
              <span id="preview-quote-author">AI</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </form>
</AdminLayout>

<script>
  import { getLlmSettings, requestLlmChat } from "../../scripts/admin-llm";

  const HOME_KEY = "admin-home-data";
  const form = document.getElementById("home-form");
  const guidanceInput = document.getElementById("generation-guidance");
  const previewTitle = document.getElementById("preview-title");
  const previewLead = document.getElementById("preview-lead");
  const previewQuoteText = document.getElementById("preview-quote-text");
  const previewQuoteAuthor = document.getElementById("preview-quote-author");
  const saveStatus = document.getElementById("save-status");
  const dailyBadge = document.getElementById("daily-badge");
  const generatedDate = document.getElementById("generated-date");
  const btnGenerate = document.getElementById("btn-generate-daily");
  const btnReset = document.getElementById("btn-reset");

  let generatedData = {
    generatedDate: "",
    guidance: "",
    heroTitle: "",
    heroLead: "",
    quoteText: "",
    quoteAuthor: "",
  };

  function todayKey() {
    const now = new Date();
    return `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, "0")}-${String(now.getDate()).padStart(2, "0")}`;
  }

  function showStatus(text, type) {
    if (!saveStatus) return;
    saveStatus.textContent = text;
    saveStatus.className = "save-status is-" + type;
    if (type !== "info") {
      setTimeout(() => {
        saveStatus.textContent = "";
        saveStatus.className = "save-status";
      }, 3000);
    }
  }

  function updateBadges() {
    const isToday = generatedData.generatedDate === todayKey();
    if (dailyBadge) {
      dailyBadge.textContent = isToday ? "今日已生成" : "今日未生成";
      dailyBadge.className = isToday ? "section-badge is-ok" : "section-badge";
    }
    if (generatedDate) generatedDate.textContent = generatedData.generatedDate || "未保存";
  }

  function updatePreview() {
    if (previewTitle) {
      previewTitle.textContent = generatedData.heroTitle || "等待生成";
      previewTitle.style.whiteSpace = "pre-line";
    }
    if (previewLead) previewLead.textContent = generatedData.heroLead || "填写方向后生成今日首页前言。";
    if (previewQuoteText) previewQuoteText.textContent = generatedData.quoteText || "等待生成";
    if (previewQuoteAuthor) previewQuoteAuthor.textContent = generatedData.quoteAuthor || "AI";
    updateBadges();
  }

  function saveHomeData() {
    localStorage.setItem(HOME_KEY, JSON.stringify(generatedData));
    window.dispatchEvent(new CustomEvent("admin-content:changed", {
      detail: { key: "home" },
    }));
  }

  function loadHomeData() {
    try {
      const saved = localStorage.getItem(HOME_KEY);
      if (!saved) return;
      const data = JSON.parse(saved);
      generatedData = {
        ...generatedData,
        ...data,
      };
      if (guidanceInput) guidanceInput.value = generatedData.guidance || "";
    } catch {}
  }

  function parseGeneratedJson(content) {
    const cleaned = content
      .trim()
      .replace(/^```(?:json)?/i, "")
      .replace(/```$/i, "")
      .trim();
    const jsonStart = cleaned.indexOf("{");
    const jsonEnd = cleaned.lastIndexOf("}");
    const jsonText = jsonStart >= 0 && jsonEnd > jsonStart
      ? cleaned.slice(jsonStart, jsonEnd + 1)
      : cleaned;
    const data = JSON.parse(jsonText);
    return {
      heroTitle: String(data.heroTitle || "").trim(),
      heroLead: String(data.heroLead || "").trim(),
      quoteText: String(data.quoteText || "").trim(),
      quoteAuthor: String(data.quoteAuthor || "").trim(),
    };
  }

  btnGenerate?.addEventListener("click", async () => {
    const settings = getLlmSettings();
    if (!settings?.baseUrl || !settings?.apiKey || !settings?.model) {
      showStatus("请先在 API 管理中配置 LLM API", "error");
      return;
    }

    const date = todayKey();
    const guidance = guidanceInput?.value?.trim() || "保持克制、真诚、适合个人博客首页的表达。";
    const prompt = `今天日期：${date}
生成方向：${guidance}

请为个人博客首页生成每日前言和引言，要求：
1. heroTitle 为首页主标题，12 个汉字以内，可以包含一次换行。
2. heroLead 为首页描述，60 个汉字以内。
3. quoteText 为引言内容，40 个汉字以内。
4. quoteAuthor 为引言署名，可为“AI”或贴合内容的短署名。
5. 只输出 JSON，不要输出 Markdown 或解释。

JSON 字段：heroTitle, heroLead, quoteText, quoteAuthor。`;

    if (btnGenerate) btnGenerate.disabled = true;
    showStatus("正在生成今日内容...", "info");

    try {
      const content = await requestLlmChat({
        messages: [
          { role: "system", content: "你是个人博客首页文案助手，输出必须是可解析的 JSON。" },
          { role: "user", content: prompt },
        ],
        temperature: 0.8,
        onSlow: () => showStatus("API 响应较慢，请继续等待...", "info"),
      });
      const result = parseGeneratedJson(content);
      generatedData = {
        ...generatedData,
        ...result,
        guidance,
        generatedDate: date,
      };
      if (guidanceInput) guidanceInput.value = guidance;
      updatePreview();
      saveHomeData();
      showStatus("今日内容已生成并保存", "success");
    } catch (err) {
      showStatus("生成失败: " + (err instanceof Error ? err.message : String(err)), "error");
    } finally {
      if (btnGenerate) btnGenerate.disabled = false;
    }
  });

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!generatedData.heroTitle && !generatedData.heroLead && !generatedData.quoteText) {
      showStatus("请先生成今日内容", "error");
      return;
    }
    generatedData.guidance = guidanceInput?.value?.trim() || generatedData.guidance || "";
    generatedData.generatedDate = generatedData.generatedDate || todayKey();
    saveHomeData();
    updatePreview();
    showStatus("已保存今日内容", "success");
  });

  btnReset?.addEventListener("click", async () => {
    if (!await (window as any).showConfirmDialog("确定要清除今日生成结果吗？")) return;
    localStorage.removeItem(HOME_KEY);
    generatedData = {
      generatedDate: "",
      guidance: "",
      heroTitle: "",
      heroLead: "",
      quoteText: "",
      quoteAuthor: "",
    };
    if (guidanceInput) guidanceInput.value = "";
    updatePreview();
    window.dispatchEvent(new CustomEvent("admin-content:changed", {
      detail: { key: "home" },
    }));
    showStatus("已清除今日结果", "success");
  });

  loadHomeData();
  updatePreview();
</script>

<style>
  .admin-page-header {
    margin-bottom: 24px;
  }
  .admin-page-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: #181c23;
    margin-bottom: 6px;
  }
  .admin-page-desc {
    font-size: 15px;
    color: #717785;
  }
  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-section {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(24px);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 20px;
    padding: 28px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.03);
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 6px;
  }
  .section-title {
    font-size: 18px;
    font-weight: 600;
    color: #181c23;
  }
  .section-badge {
    padding: 3px 10px;
    border-radius: 8px;
    background: rgba(0,89,181,0.08);
    color: #0059b5;
    font-size: 12px;
    font-weight: 500;
  }
  .section-badge.is-ok {
    background: rgba(5,150,105,0.1);
    color: #059669;
  }
  .section-desc {
    font-size: 14px;
    color: #717785;
    margin-bottom: 20px;
  }
  .field-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .field-label {
    font-size: 14px;
    font-weight: 500;
    color: #181c23;
  }
  .field-input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(193,198,214,0.5);
    background: rgba(255,255,255,0.7);
    font-family: var(--font-body);
    font-size: 15px;
    color: #181c23;
    outline: none;
    transition: border-color 0.2s cubic-bezier(0.23, 1, 0.32, 1), box-shadow 0.2s cubic-bezier(0.23, 1, 0.32, 1), transform 0.12s cubic-bezier(0.23, 1, 0.32, 1);
    box-sizing: border-box;
    transform: scale(1);
  }
  .field-input:active {
    transform: scale(0.995);
  }
  .field-input:focus {
    border-color: #0059b5;
    box-shadow: 0 0 0 3px rgba(0,89,181,0.1);
  }
  .field-textarea {
    resize: vertical;
    min-height: 100px;
    line-height: 1.6;
  }
  .field-hint {
    font-size: 12px;
    color: #717785;
  }
  .preview-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 16px;
  }
  .preview-box {
    padding: 20px;
    border-radius: 16px;
    background: rgba(244,246,250,0.8);
    border: 1px solid rgba(193,198,214,0.3);
  }
  .preview-label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: #717785;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }
  .preview-hero,
  .preview-quote {
    padding: 24px;
    background: rgba(255,255,255,0.8);
    border-radius: 12px;
    min-height: 148px;
  }
  .preview-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    line-height: 1.1;
    color: #181c23;
    margin: 0 0 12px;
  }
  .preview-lead {
    font-size: 15px;
    line-height: 1.5;
    color: #414753;
    margin: 0;
  }
  .preview-quote-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 9999px;
    background: rgba(193,198,214,0.3);
    font-size: 12px;
    font-weight: 500;
    color: #414753;
    margin-bottom: 16px;
  }
  .preview-quote-body {
    font-size: 18px;
    font-style: italic;
    line-height: 1.5;
    color: #181c23;
    margin: 0 0 16px;
    padding: 0;
    border: none;
  }
  .preview-quote-author {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: #717785;
  }
  .preview-quote-line {
    display: block;
    width: 32px;
    height: 1px;
    background: rgba(193,198,214,0.6);
  }
  .form-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    padding-top: 18px;
  }
  .btn-primary,
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s cubic-bezier(0.23, 1, 0.32, 1), border-color 0.2s cubic-bezier(0.23, 1, 0.32, 1), color 0.2s cubic-bezier(0.23, 1, 0.32, 1), transform 0.15s cubic-bezier(0.23, 1, 0.32, 1);
    transform: scale(1);
  }
  .btn-primary {
    border: none;
    background: #0059b5;
    color: #ffffff;
  }
  .btn-primary:hover {
    background: #004a94;
  }
  .btn-primary:disabled {
    opacity: 0.65;
    cursor: wait;
  }
  .btn-secondary {
    border: 1px solid rgba(193,198,214,0.5);
    background: rgba(255,255,255,0.6);
    color: #414753;
  }
  .btn-secondary:hover {
    background: rgba(255,255,255,0.9);
    border-color: rgba(113,119,133,0.4);
    color: #181c23;
  }
  .btn-primary:active,
  .btn-secondary:active {
    transform: scale(0.97);
  }
  .save-status {
    font-size: 14px;
    color: #717785;
    min-height: 20px;
  }
  .save-status.is-success { color: #0d8a4f; }
  .save-status.is-error { color: #b91c1c; }
  .save-status.is-info { color: #0059b5; }

  @media (max-width: 900px) {
    .preview-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .form-section {
      padding: 22px;
    }
    .preview-title {
      font-size: 26px;
    }
  }
</style>
