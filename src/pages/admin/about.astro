---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { normalizeAbout, readNeonAbout } from "../../lib/neon-content";
import { ABOUT_AVATAR_PLACEHOLDER } from "../../lib/placeholder-images";

const DEFAULT_AVATAR = ABOUT_AVATAR_PLACEHOLDER;
const initialAbout = (await readNeonAbout().catch(() => null)) ?? normalizeAbout({});
const initialAvatar = initialAbout.avatar || DEFAULT_AVATAR;
---

<AdminLayout title="关于管理" current="about">
  <div class="admin-page-header">
    <h1 class="admin-page-title">关于管理</h1>
    <p class="admin-page-desc">编辑个人资料、头像、理念与技能标签。</p>
  </div>

  <form id="about-form" class="admin-form">
    {/* Avatar Upload */}
    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">头像</h2>
        <span class="section-badge">固定位置</span>
      </div>
      <p class="section-desc">前台关于页面左上角显示的头像，建议使用正方形或接近正方形的图片。</p>

      <div class="avatar-upload-wrap">
        <input type="file" id="avatar-input" accept="image/jpeg,image/png,image/gif,image/webp,image/bmp,image/tiff" class="cover-upload-input" />
        <div id="avatar-preview-area" class="avatar-preview-area">
          <div class="avatar-placeholder" id="avatar-placeholder">
            <img id="avatar-preview-img" src={initialAvatar} alt="头像预览" class="avatar-preview-img" />
            <span class="avatar-upload-copy">
              <span>点击更换头像</span>
              <small>支持 JPG、PNG 格式，最大 5MB</small>
            </span>
          </div>
          <button type="button" id="btn-remove-avatar" class="btn-remove-avatar" title="恢复默认头像">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12"/><path d="M3 3v9h9"/></svg>
          </button>
        </div>
        <div id="avatar-progress" class="cover-progress hidden">
          <div class="progress-bar"><div class="progress-fill" id="avatar-progress-fill"></div></div>
          <span class="progress-text" id="avatar-progress-text">0%</span>
        </div>
        <div id="avatar-status" class="cover-status"></div>
        <input type="hidden" id="avatar-data" name="avatar" value={initialAvatar} />
      </div>
    </section>

    {/* Basic Info */}
    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">基本信息</h2>
        <span class="section-badge">元数据</span>
      </div>

      <div class="field-row">
        <div class="field-group">
          <label for="about-name" class="field-label">名字</label>
          <input id="about-name" name="name" type="text" class="field-input" value={initialAbout.name} placeholder="显示名称" />
        </div>
        <div class="field-group">
          <label for="about-role" class="field-label">角色</label>
          <input id="about-role" name="role" type="text" class="field-input" value={initialAbout.role} placeholder="职业身份" />
        </div>
      </div>

      <div class="field-group" style="margin-top: 16px;">
        <label for="about-bio" class="field-label">简介（首页 Hero 使用）</label>
        <textarea id="about-bio" name="bio" class="field-input field-textarea" rows="2" placeholder="简短的个人简介">{initialAbout.bio}</textarea>
      </div>

      <div class="field-group" style="margin-top: 16px;">
        <label for="about-desc" class="field-label">描述（关于页面使用）</label>
        <textarea id="about-desc" name="description" class="field-input field-textarea" rows="3" placeholder="详细的个人描述">{initialAbout.description}</textarea>
      </div>
    </section>

    {/* Philosophy Markdown Editor */}
    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">理念</h2>
        <span class="section-badge">Markdown</span>
      </div>
      <p class="section-desc">支持 Markdown 格式，每段理念之间用空行分隔。</p>

      <div class="field-group">
        <div class="editor-toolbar">
          <label class="field-label">理念内容</label>
          <div class="editor-actions">
            <button type="button" class="toolbar-btn" data-action="bold" title="粗体">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
            </button>
            <button type="button" class="toolbar-btn" data-action="italic" title="斜体">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>
            </button>
            <button type="button" class="toolbar-btn" data-action="heading" title="标题">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 12h12"/><path d="M6 20V4"/><path d="M18 20V4"/></svg>
            </button>
            <button type="button" class="toolbar-btn" data-action="quote" title="引用">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21"/></svg>
            </button>
            <button type="button" class="toolbar-btn" data-action="link" title="链接">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
            <button type="button" class="toolbar-btn" data-action="ul" title="无序列表">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
            </button>
            <span class="toolbar-divider"></span>
            <button type="button" class="toolbar-btn toolbar-btn-polish" id="btn-polish" title="AI 润色">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
            </button>
          </div>
        </div>
        <div class="markdown-renderer" data-markdown-renderer>
          <div class="markdown-renderer-pane is-active" data-markdown-edit-pane>
            <textarea id="philosophy-content" name="philosophy" class="field-input field-textarea editor-textarea" rows="10" placeholder="在此输入 Markdown 格式的理念内容...&#10;&#10;每段之间用空行分隔。" data-markdown-source>{initialAbout.philosophy?.join("\n\n")}</textarea>
          </div>
        </div>

        {/* AI Polish Options */}
        <div class="polish-options hidden" id="polish-options">
          <div class="polish-options-bar">
            <label class="field-label" style="margin-bottom:0">AI 润色</label>
            <div class="polish-presets">
              <button type="button" class="polish-preset active" data-preset="polite">润色修饰</button>
              <button type="button" class="polish-preset" data-preset="concise">精简紧凑</button>
              <button type="button" class="polish-preset" data-preset="expand">扩写丰富</button>
              <button type="button" class="polish-preset" data-preset="translate">翻译为英文</button>
            </div>
            <div class="polish-actions">
              <button type="button" id="btn-polish-run" class="btn-primary btn-small">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
                执行润色
              </button>
              <button type="button" id="btn-polish-cancel" class="btn-secondary btn-small">取消</button>
            </div>
          </div>
          <div class="polish-custom-prompt">
            <input id="polish-custom" type="text" class="field-input" placeholder="自定义润色指令，如：用更学术的语气改写（可选）" />
          </div>
          <div id="polish-status" class="polish-status"></div>
          {/* Diff Preview */}
          <div class="polish-diff hidden" id="polish-diff">
            <div class="diff-header">
              <span class="diff-label">润色结果预览</span>
              <div class="diff-actions">
                <button type="button" id="btn-apply-polish" class="btn-primary btn-small">应用</button>
                <button type="button" id="btn-discard-polish" class="btn-secondary btn-small">放弃</button>
              </div>
            </div>
            <div class="diff-body" id="polish-diff-body"></div>
          </div>
        </div>
      </div>
    </section>

    {/* Skills */}
    <section class="form-section">
      <div class="section-header">
        <h2 class="section-title">技能标签</h2>
        <span class="section-badge">标签</span>
      </div>
      <p class="section-desc">输入技能名称后按回车添加，点击标签上的 × 移除。</p>

      <div class="field-group">
        <label class="field-label">核心能力</label>
        <div class="tag-input-wrap">
          <div id="skill-list" class="tag-list"></div>
          <input id="skill-input" type="text" class="tag-input" placeholder="输入技能后按回车添加" />
        </div>
        <input type="hidden" id="about-skills" name="skills" value={initialAbout.skills?.join(",")} />
      </div>
    </section>

    {/* Actions */}
    <div class="form-actions">
      <button type="submit" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        保存更改
      </button>
      <button type="button" id="btn-reset" class="btn-secondary">重置</button>
      <span id="save-status" class="save-status"></span>
    </div>
  </form>
</AdminLayout>

<script>
  import { initMarkdownRenderers } from "../../scripts/admin-markdown-renderer";

  initMarkdownRenderers();
</script>

<script define:vars={{ defaultAvatar: DEFAULT_AVATAR, initialAbout }}>
  const ABOUT_KEY = "admin-about-data";
  const ABOUT_API = "/api/about";
  const DEFAULT_AVATAR = defaultAvatar;

  // ===== Elements =====
  const form = document.getElementById("about-form");
  const saveStatus = document.getElementById("save-status");

  // Avatar
  const avatarInput = document.getElementById("avatar-input");
  const avatarPreviewImg = document.getElementById("avatar-preview-img");
  const avatarPlaceholder = document.getElementById("avatar-placeholder");
  const btnRemoveAvatar = document.getElementById("btn-remove-avatar");
  const avatarData = document.getElementById("avatar-data");
  const avatarProgress = document.getElementById("avatar-progress");
  const avatarProgressFill = document.getElementById("avatar-progress-fill");
  const avatarProgressText = document.getElementById("avatar-progress-text");
  const avatarStatus = document.getElementById("avatar-status");

  avatarPreviewImg?.addEventListener("error", () => {
    if (!avatarPreviewImg.src.endsWith(DEFAULT_AVATAR)) {
      avatarPreviewImg.src = DEFAULT_AVATAR;
      if (avatarData) avatarData.value = DEFAULT_AVATAR;
    }
  });

  // Fields
  const nameInput = document.getElementById("about-name");
  const roleInput = document.getElementById("about-role");
  const bioInput = document.getElementById("about-bio");
  const descInput = document.getElementById("about-desc");
  const philosophyInput = document.getElementById("philosophy-content");
  const skillInput = document.getElementById("skill-input");
  const skillList = document.getElementById("skill-list");
  const skillsHidden = document.getElementById("about-skills");

  let currentSkills = Array.isArray(initialAbout.skills) ? [...initialAbout.skills] : [];

  function syncPhilosophyPreview() {
    philosophyInput?.dispatchEvent(new Event("input", { bubbles: true }));
  }

  // ===== Helpers =====
  function showStatus(text, type) {
    if (!saveStatus) return;
    saveStatus.textContent = text;
    saveStatus.className = "save-status is-" + type;
    setTimeout(() => {
      saveStatus.textContent = "";
      saveStatus.className = "save-status";
    }, 3000);
  }

  function notifyContentChanged() {
    window.dispatchEvent(new CustomEvent("admin-content:changed", {
      detail: { key: ABOUT_KEY, module: "about" },
    }));
  }

  function applyAboutData(data) {
    if (!data || typeof data !== "object") return;

    if (data.avatar && avatarPreviewImg) {
      avatarPreviewImg.src = data.avatar;
      if (avatarData) avatarData.value = data.avatar;
    }
    if (typeof data.name === "string" && nameInput) nameInput.value = data.name;
    if (typeof data.role === "string" && roleInput) roleInput.value = data.role;
    if (typeof data.bio === "string" && bioInput) bioInput.value = data.bio;
    if (typeof data.description === "string" && descInput) descInput.value = data.description;
    if (Array.isArray(data.philosophy) && philosophyInput) {
      philosophyInput.value = data.philosophy.join("\n\n");
      syncPhilosophyPreview();
    }
    if (Array.isArray(data.skills)) {
      currentSkills = data.skills;
      renderSkills();
    }
  }

  async function loadSavedData() {
    try {
      const response = await fetch(ABOUT_API, {
        headers: { accept: "application/json" },
        cache: "no-store",
      });
      const result = await response.json().catch(() => ({}));
      if (response.ok && result.ok && result.about) {
        applyAboutData(result.about);
        localStorage.setItem(ABOUT_KEY, JSON.stringify(result.about));
        return;
      }
    } catch {}

    try {
      const raw = localStorage.getItem(ABOUT_KEY);
      if (raw) applyAboutData(JSON.parse(raw));
    } catch {}
  }

  // ===== Avatar Upload =====
  const AVATAR_MAX_SIZE = 5 * 1024 * 1024;
  const AVATAR_ACCEPT_TYPES = ["image/jpeg", "image/png", "image/gif", "image/webp", "image/bmp", "image/tiff"];

  function setAvatarProgress(percent) {
    if (avatarProgressFill) avatarProgressFill.style.width = percent + "%";
    if (avatarProgressText) avatarProgressText.textContent = percent + "%";
  }

  function showAvatarStatus(text, type) {
    if (!avatarStatus) return;
    avatarStatus.textContent = text;
    avatarStatus.className = "cover-status is-" + type;
  }

  function validateAvatarFile(file) {
    if (!AVATAR_ACCEPT_TYPES.includes(file.type)) {
      showAvatarStatus("仅支持 JPG、PNG、GIF、WebP 格式", "error");
      return false;
    }
    if (file.size > AVATAR_MAX_SIZE) {
      showAvatarStatus(`文件过大 (${(file.size/1024/1024).toFixed(1)}MB)，最大支持 5MB`, "error");
      return false;
    }
    return true;
  }

  function uploadImageWithProgress(endpoint, file, onProgress) {
    return new Promise((resolve, reject) => {
      const formData = new FormData();
      formData.append("image", file);
      const xhr = new XMLHttpRequest();
      xhr.open("POST", endpoint);
      xhr.responseType = "json";
      xhr.upload.addEventListener("progress", (event) => {
        if (!event.lengthComputable) return;
        onProgress(Math.round((event.loaded / event.total) * 100));
      });
      xhr.addEventListener("load", () => {
        const response = xhr.response || {};
        if (xhr.status >= 200 && xhr.status < 300 && response.ok) {
          resolve(response.image);
          return;
        }
        reject(new Error(response.message || "上传失败"));
      });
      xhr.addEventListener("error", () => reject(new Error("网络错误")));
      xhr.addEventListener("abort", () => reject(new Error("上传已取消")));
      xhr.send(formData);
    });
  }

  async function processAvatarImage(file) {
    if (!validateAvatarFile(file)) return null;
    if (avatarProgress) avatarProgress.classList.remove("hidden");
    setAvatarProgress(0);
    showAvatarStatus("正在上传头像...", "info");

    try {
      const image = await uploadImageWithProgress("/api/upload/cover", file, setAvatarProgress);
      setAvatarProgress(100);
      if (avatarPreviewImg) avatarPreviewImg.src = image.url;
      if (avatarData) avatarData.value = image.url;
      showAvatarStatus("头像上传成功", "success");
      setTimeout(() => { if (avatarProgress) avatarProgress.classList.add("hidden"); }, 500);
      return image.url;
    } catch (err) {
      showAvatarStatus(err instanceof Error ? err.message : "头像上传失败", "error");
      if (avatarProgress) avatarProgress.classList.add("hidden");
      return null;
    }
  }

  avatarInput?.addEventListener("change", async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    await processAvatarImage(file);
    avatarInput.value = "";
  });

  btnRemoveAvatar?.addEventListener("click", () => {
    if (avatarPreviewImg) avatarPreviewImg.src = DEFAULT_AVATAR;
    if (avatarData) avatarData.value = DEFAULT_AVATAR;
    showAvatarStatus("已恢复默认头像", "info");
  });

  // ===== Markdown Toolbar =====
  let lastMarkdownSelection = null;

  function clampSelectionOffset(value, min, max) {
    return Math.min(Math.max(value, min), max);
  }

  function getLiveEditorSelectionOffset(editor, node, offset) {
    const element = node.nodeType === Node.ELEMENT_NODE ? node : node.parentElement;
    const line = node === editor
      ? editor.querySelector("[data-live-line]")
      : element?.closest("[data-live-line]");
    if (!line) return null;

    let lineStart = 0;
    for (const item of editor.querySelectorAll("[data-live-line]")) {
      if (item === line) break;
      lineStart += (item.dataset.prefix || "").length + (item.textContent || "").length + 1;
    }

    const range = document.createRange();
    range.selectNodeContents(line);
    try {
      range.setEnd(node, offset);
    } catch {
      range.detach();
      return lineStart + (line.dataset.prefix || "").length + (line.textContent || "").length;
    }

    const textOffset = clampSelectionOffset(range.toString().length, 0, (line.textContent || "").length);
    range.detach();
    return lineStart + (line.dataset.prefix || "").length + textOffset;
  }

  function getCurrentLiveMarkdownSelection() {
    const editor = document.querySelector("[data-markdown-live-editor]");
    const selection = window.getSelection();
    if (!editor || !selection || selection.rangeCount === 0) return null;

    const range = selection.getRangeAt(0);
    if (!editor.contains(range.startContainer) || !editor.contains(range.endContainer)) {
      return null;
    }

    const start = getLiveEditorSelectionOffset(editor, range.startContainer, range.startOffset);
    const end = getLiveEditorSelectionOffset(editor, range.endContainer, range.endOffset);
    if (start === null || end === null) return null;

    return {
      start: Math.min(start, end),
      end: Math.max(start, end),
    };
  }

  function rememberMarkdownSelection() {
    const selection = getCurrentLiveMarkdownSelection();
    if (selection) lastMarkdownSelection = selection;
  }

  function getMarkdownSelection() {
    const liveSelection = getCurrentLiveMarkdownSelection();
    if (liveSelection) {
      lastMarkdownSelection = liveSelection;
      return liveSelection;
    }

    if (lastMarkdownSelection) return lastMarkdownSelection;

    return {
      start: philosophyInput?.selectionStart || 0,
      end: philosophyInput?.selectionEnd || 0,
    };
  }

  document.addEventListener("selectionchange", rememberMarkdownSelection);
  document.querySelector("[data-markdown-live-editor]")?.addEventListener("keyup", rememberMarkdownSelection);
  document.querySelector("[data-markdown-live-editor]")?.addEventListener("mouseup", rememberMarkdownSelection);

  const toolbarBtns = document.querySelectorAll(".toolbar-btn");
  philosophyInput?.addEventListener("input", () => {
    lastMarkdownSelection = null;
  });

  toolbarBtns.forEach((btn) => {
    btn.addEventListener("mousedown", (e) => {
      if (btn.dataset.action) e.preventDefault();
    });

    btn.addEventListener("click", () => {
      const action = btn.dataset.action;
      if (!action || !philosophyInput) return;
      const selection = getMarkdownSelection();
      const text = philosophyInput.value;
      let start = selection.start;
      let end = selection.end;

      if (["heading", "quote", "ul"].includes(action)) {
        start = text.lastIndexOf("\n", Math.max(0, start - 1)) + 1;
        const lineEnd = text.indexOf("\n", end);
        end = lineEnd === -1 ? text.length : lineEnd;
      }

      const selected = text.substring(start, end);
      let replacement = selected;
      let cursorOffset = 0;

      switch (action) {
        case "bold":
          replacement = `**${selected || "粗体文字"}**`;
          cursorOffset = selected ? 0 : -4;
          break;
        case "italic":
          replacement = `*${selected || "斜体文字"}*`;
          cursorOffset = selected ? 0 : -4;
          break;
        case "heading":
          replacement = `\n### ${selected || "标题"}\n`;
          cursorOffset = selected ? 0 : -1;
          break;
        case "quote":
          replacement = `\n> ${selected || "引用文字"}\n`;
          cursorOffset = selected ? 0 : -1;
          break;
        case "link":
          replacement = `[${selected || "链接文字"}](https://)`;
          cursorOffset = selected ? 0 : -10;
          break;
        case "ul":
          replacement = `\n- ${selected || "列表项"}\n`;
          cursorOffset = selected ? 0 : -1;
          break;
      }

      philosophyInput.value = text.substring(0, start) + replacement + text.substring(end);
      philosophyInput.selectionStart = philosophyInput.selectionEnd = start + replacement.length + cursorOffset;
      lastMarkdownSelection = {
        start: philosophyInput.selectionStart,
        end: philosophyInput.selectionEnd,
      };
      philosophyInput.focus();
      syncPhilosophyPreview();
    });
  });

  // ===== Skills Tag System =====
  function renderSkills() {
    if (!skillList) return;
    skillList.innerHTML = currentSkills.map((skill, idx) => `
      <span class="tag-chip">
        ${skill.replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]))}
        <button type="button" class="tag-remove" data-idx="${idx}">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </span>
    `).join("");
    if (skillsHidden) skillsHidden.value = currentSkills.join(",");
    if (skillInput) skillInput.disabled = currentSkills.length >= 10;
    if (skillInput) skillInput.placeholder = currentSkills.length >= 10 ? "已达 10 个上限" : "输入技能后按回车添加";
  }

  skillInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      const val = skillInput.value.trim();
      if (!val) return;
      if (currentSkills.length >= 10) {
        showStatus("最多 10 个标签", "error");
        return;
      }
      if (currentSkills.includes(val)) {
        showStatus("标签已存在", "error");
        return;
      }
      currentSkills.push(val);
      skillInput.value = "";
      renderSkills();
    }
    if (e.key === "Backspace" && !skillInput.value && currentSkills.length > 0) {
      currentSkills.pop();
      renderSkills();
    }
  });

  skillList?.addEventListener("click", (e) => {
    const btn = e.target.closest(".tag-remove");
    if (!btn) return;
    const idx = parseInt(btn.dataset.idx || "-1", 10);
    if (idx >= 0) {
      currentSkills.splice(idx, 1);
      renderSkills();
    }
  });

  // ===== Save / Reset =====
  async function saveAbout(data) {
    localStorage.setItem(ABOUT_KEY, JSON.stringify(data));
    notifyContentChanged();

    try {
      const response = await fetch(ABOUT_API, {
        method: "PUT",
        headers: {
          "content-type": "application/json",
          "x-admin-auth": localStorage.getItem("admin-auth") || "",
        },
        body: JSON.stringify({ about: data }),
      });
      const result = await response.json().catch(() => ({}));
      if (!response.ok || !result.ok) {
        throw new Error(result.message || "云端同步失败");
      }

      if (result.about) {
        localStorage.setItem(ABOUT_KEY, JSON.stringify(result.about));
        notifyContentChanged();
      }
      showStatus("已保存到 Neon", "success");
      return true;
    } catch (err) {
      showStatus(err instanceof Error ? `云端同步失败：${err.message}` : "云端同步失败", "error");
      return false;
    }
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const philosophyText = philosophyInput?.value || "";
    const philosophyParagraphs = philosophyText
      .split(/\n\n+/)
      .map((p) => p.trim())
      .filter((p) => p.length > 0);

    const data = {
      name: nameInput?.value || "",
      role: roleInput?.value || "",
      avatar: avatarData?.value || DEFAULT_AVATAR,
      bio: bioInput?.value || "",
      description: descInput?.value || "",
      philosophy: philosophyParagraphs,
      skills: currentSkills,
    };

    await saveAbout(data);
  });

  document.getElementById("btn-reset")?.addEventListener("click", async () => {
    if (await window.showConfirmDialog("确定要重置为默认内容吗？")) {
      localStorage.removeItem(ABOUT_KEY);
      location.reload();
    }
  });

  // Init
  void loadSavedData();
  renderSkills();

  // ===== AI Polish =====
  const LLM_KEY = "admin-llm-settings";
  const polishOptions = document.getElementById("polish-options");
  const btnPolish = document.getElementById("btn-polish");
  const btnPolishRun = document.getElementById("btn-polish-run");
  const btnPolishCancelEl = document.getElementById("btn-polish-cancel");
  const polishCustom = document.getElementById("polish-custom");
  const polishStatusEl = document.getElementById("polish-status");
  const polishDiff = document.getElementById("polish-diff");
  const polishDiffBody = document.getElementById("polish-diff-body");
  const btnApplyPolish = document.getElementById("btn-apply-polish");
  const btnDiscardPolish = document.getElementById("btn-discard-polish");

  let polishedContent = "";
  let currentPreset = "polite";

  const PRESET_PROMPTS = {
    polite: "请润色以下 Markdown 文本，使其更加流畅、优雅，修正语法和用词，但保留原始含义和 Markdown 格式不变。只输出润色后的内容，不要解释。",
    concise: "请精简以下 Markdown 文本，删除冗余词句，使其更加紧凑有力，但保留核心含义和 Markdown 格式不变。只输出精简后的内容，不要解释。",
    expand: "请扩写以下 Markdown 文本，在保留原意的基础上增加更多细节和论述，使内容更加丰富充实，Markdown 格式不变。只输出扩写后的内容，不要解释。",
    translate: "请将以下 Markdown 文本翻译为英文，保持 Markdown 格式不变。只输出翻译后的内容，不要解释。",
  };

  function getLlmSettings() {
    try {
      const raw = localStorage.getItem(LLM_KEY);
      if (raw) return JSON.parse(raw);
    } catch {}
    return null;
  }

  function escapeHtml(str) {
    return (str || "").replace(/[&<>"']/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"}[c]));
  }

  function showPolishStatus(text, type) {
    if (!polishStatusEl) return;
    polishStatusEl.textContent = text;
    polishStatusEl.className = "polish-status is-" + type;
  }

  document.querySelectorAll(".polish-preset").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".polish-preset").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      currentPreset = btn.dataset.preset || "polite";
    });
  });

  btnPolish?.addEventListener("click", () => {
    if (!philosophyInput?.value?.trim()) {
      showStatus("请先输入理念内容", "error");
      return;
    }
    const s = getLlmSettings();
    if (!s || !s.baseUrl || !s.apiKey || !s.model) {
      showStatus("请先在 API 管理中配置 LLM API", "error");
      return;
    }
    if (polishOptions) polishOptions.classList.remove("hidden");
    if (polishDiff) polishDiff.classList.add("hidden");
    polishedContent = "";
  });

  btnPolishCancelEl?.addEventListener("click", () => {
    if (polishOptions) polishOptions.classList.add("hidden");
    if (polishDiff) polishDiff.classList.add("hidden");
    polishedContent = "";
  });

  btnPolishRun?.addEventListener("click", async () => {
    const content = philosophyInput?.value?.trim();
    if (!content) {
      showPolishStatus("没有可润色的内容", "error");
      return;
    }
    const s = getLlmSettings();
    if (!s || !s.baseUrl || !s.apiKey || !s.model) {
      showPolishStatus("LLM API 未配置，请前往 API 管理页面配置", "error");
      return;
    }

    const customPrompt = polishCustom?.value?.trim();
    const systemPrompt = customPrompt || PRESET_PROMPTS[currentPreset] || PRESET_PROMPTS.polite;

    if (btnPolishRun) btnPolishRun.disabled = true;
    showPolishStatus("正在润色中，请稍候...", "info");

    const slowTimer = window.setTimeout(() => {
      showPolishStatus("API 响应较慢，请继续等待...", "info");
    }, 8000);

    try {
      const res = await fetch("/api/llm", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          baseUrl: s.baseUrl,
          apiKey: s.apiKey,
          model: s.model,
          messages: [
            { role: "system", content: systemPrompt },
            { role: "user", content: content },
          ],
          temperature: 0.7,
        }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) {
        throw new Error(data.message || `HTTP ${res.status}`);
      }
      polishedContent = typeof data.content === "string" ? data.content.trim() : "";
      if (!polishedContent) throw new Error("API 返回内容为空");

      showPolishStatus("润色完成，请预览对比", "success");
      renderDiff(content, polishedContent);
      if (polishDiff) polishDiff.classList.remove("hidden");
    } catch (err) {
      showPolishStatus("润色失败: " + (err instanceof Error ? err.message : String(err)), "error");
    } finally {
      window.clearTimeout(slowTimer);
      if (btnPolishRun) btnPolishRun.disabled = false;
    }
  });

  function renderDiff(original, polished) {
    if (!polishDiffBody) return;
    let html = '<div class="diff-content">';
    html += '<div class="diff-section"><div class="diff-section-label">润色后</div><pre class="diff-pre diff-new">' + escapeHtml(polished) + '</pre></div>';
    html += '<div class="diff-section"><div class="diff-section-label">原始内容</div><pre class="diff-pre diff-old">' + escapeHtml(original) + '</pre></div>';
    html += '</div>';
    polishDiffBody.innerHTML = html;
  }

  btnApplyPolish?.addEventListener("click", () => {
    if (polishedContent && philosophyInput) {
      philosophyInput.value = polishedContent;
      syncPhilosophyPreview();
      showStatus("已应用润色结果", "success");
    }
    if (polishOptions) polishOptions.classList.add("hidden");
    if (polishDiff) polishDiff.classList.add("hidden");
    polishedContent = "";
  });

  btnDiscardPolish?.addEventListener("click", () => {
    if (polishDiff) polishDiff.classList.add("hidden");
    polishedContent = "";
    showPolishStatus("已放弃润色结果", "info");
  });
</script>

