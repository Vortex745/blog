---
import "../styles/globals.css";

export interface Props {
  title: string;
  current?: string;
}

const { title, current = "" } = Astro.props;

const navItems = [
  { id: "dashboard", label: "总览", href: "/admin" },
  { id: "home", label: "首页", href: "/admin/home" },
  { id: "projects", label: "项目", href: "/admin/projects" },
  { id: "articles", label: "文章", href: "/admin/articles" },
  { id: "gallery", label: "图库", href: "/admin/gallery" },
  { id: "about", label: "关于", href: "/admin/about" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — 管理后台</title>
  </head>
  <body class="admin-body">
    <div class="admin-shell">
      <!-- Sidebar -->
      <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
          <a href="/" class="admin-logo">子衿</a>
          <span class="admin-badge">管理后台</span>
        </div>
        <nav class="admin-nav" data-current={current}>
          <div class="nav-pill" aria-hidden="true"></div>
          {
            navItems.map((item) => {
              const isActive = current === item.id;
              return (
                <a
                  href={item.href}
                  class={`admin-nav-link ${isActive ? "is-active" : ""}`}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
        <div class="admin-sidebar-footer">
          <button id="admin-logout" class="admin-logout-btn" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
            退出登录
          </button>
          <a href="/" class="admin-back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            返回网站
          </a>
        </div>
      </aside>

      <!-- Main -->
      <main class="admin-main" data-admin-module={current}>
        <slot />
      </main>
    </div>

    <script>
      (function() {
        // Auth guard: redirect to login if not authenticated
        const isAuthed = localStorage.getItem("admin-auth") === "1";
        if (!isAuthed) {
          window.location.replace("/admin/login");
          return;
        }

        // Logout handler
        const logoutBtn = document.getElementById("admin-logout");
        logoutBtn?.addEventListener("click", function() {
          if (confirm("确定要退出登录吗？")) {
            localStorage.removeItem("admin-auth");
            localStorage.removeItem("admin-auth-time");
            window.location.replace("/admin/login");
          }
        });
      })();
    </script>

    <!-- Admin Animation System -->
    <script>
      import { initAdminAnimations } from "../scripts/admin-animations";
      initAdminAnimations();
    </script>
  </body>
</html>

<style>
  .admin-body {
    margin: 0;
    padding: 0;
    background: #f4f6fa;
    font-family: var(--font-body);
    color: #181c23;
    min-height: 100vh;
  }
  .admin-shell {
    display: flex;
    min-height: 100vh;
  }
  .admin-sidebar {
    width: 220px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(40px);
    border-right: 1px solid rgba(193,198,214,0.4);
    display: flex;
    flex-direction: column;
    padding: 24px 0;
    position: sticky;
    top: 0;
    height: 100vh;
  }
  .admin-sidebar-header {
    padding: 0 20px 24px;
    border-bottom: 1px solid rgba(193,198,214,0.3);
    margin-bottom: 12px;
  }
  .admin-logo {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: #181c23;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .admin-badge {
    display: inline-block;
    margin-top: 6px;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(0,89,181,0.08);
    color: #0059b5;
    font-size: 12px;
    font-weight: 500;
  }
  .admin-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0 12px;
    flex: 1;
    position: relative;
  }
  .nav-pill {
    position: absolute;
    left: 12px;
    right: 12px;
    border-radius: 10px;
    background: rgba(0,89,181,0.08);
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    will-change: transform, opacity;
  }
  .admin-nav-link {
    display: flex;
    align-items: center;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    color: #414753;
    text-decoration: none;
    position: relative;
    z-index: 1;
    transition: color 0.18s cubic-bezier(0.23, 1, 0.32, 1), transform 0.12s cubic-bezier(0.23, 1, 0.32, 1);
    transform: scale(1);
  }
  .admin-nav-link:hover {
    color: #181c23;
  }
  .admin-nav-link.is-active {
    color: #0059b5;
  }
  .admin-nav-link:active {
    transform: scale(0.97);
  }
  .admin-sidebar-footer {
    padding: 16px 20px 0;
    border-top: 1px solid rgba(193,198,214,0.3);
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .admin-logout-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: #717785;
    cursor: pointer;
    transition: color 0.18s cubic-bezier(0.23, 1, 0.32, 1), transform 0.12s cubic-bezier(0.23, 1, 0.32, 1);
    transform: scale(1);
  }
  .admin-logout-btn:hover {
    color: #b91c1c;
  }
  .admin-logout-btn:active {
    transform: scale(0.97);
  }
  .admin-back-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: #717785;
    text-decoration: none;
    transition: color 0.18s cubic-bezier(0.23, 1, 0.32, 1), transform 0.12s cubic-bezier(0.23, 1, 0.32, 1);
    transform: scale(1);
  }
  .admin-back-link:hover {
    color: #181c23;
  }
  .admin-back-link:active {
    transform: scale(0.97);
  }
  .admin-main {
    flex: 1;
    padding: 32px 40px;
    overflow-y: auto;
    will-change: transform, opacity;
  }
  @media (max-width: 768px) {
    .admin-sidebar {
      display: none;
    }
    .admin-main {
      padding: 24px;
    }
  }
</style>
