---
import "../styles/globals.css";

export interface Props {
  title: string;
  current?: string;
}

const { current = "" } = Astro.props;
const adminBrowserTitle = "子衿的个人博客后台";

const navItems = [
  { id: "dashboard", label: "总览", href: "/admin" },
  { id: "home", label: "首页", href: "/admin/home" },
  { id: "projects", label: "项目", href: "/admin/projects" },
  { id: "articles", label: "文章", href: "/admin/articles" },
  { id: "gallery", label: "图库", href: "/admin/gallery" },
  { id: "about", label: "关于", href: "/admin/about" },
  { id: "api", label: "API", href: "/admin/api" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f4f6fa" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <title>{adminBrowserTitle}</title>
    <!--
      Admin pages contain page-local management scripts (forms, modals, uploads).
      Keep the back office on normal browser navigation so those scripts are
      initialized on every page load, including production/Vercel deployments.
    -->
    <!-- Inline critical CSS to prevent FOUC and reduce CLS -->
    <style is:inline>{`
      .admin-body{margin:0;padding:0;background:#f4f6fa;font-family:"Inter","SF Pro Text","Helvetica Neue",Helvetica,Arial,sans-serif;color:#181c23;min-height:100vh}
      .admin-shell{display:flex;min-height:100vh;transition:opacity 0.12s cubic-bezier(0.23,1,0.32,1)}
      .admin-shell--hidden{opacity:0}
      .admin-sidebar{width:220px;flex-shrink:0;background:rgba(255,255,255,0.7);border-right:1px solid rgba(193,198,214,0.4);display:flex;flex-direction:column;padding:24px 0;position:sticky;top:0;height:100vh}
      .admin-main{flex:1;padding:32px 40px;overflow-y:auto}
      @media(max-width:768px){.admin-sidebar{display:none}.admin-main{padding:24px}}
    `}</style>
    <script is:inline>
      // Auth guard: redirect BEFORE paint to prevent flash of admin content
      if (localStorage.getItem("admin-auth") !== "1") {
        var redirect = encodeURIComponent(window.location.pathname);
        window.location.replace("/admin/login?redirect=" + redirect);
      }
    </script>
  </head>
  <body class="admin-body">
    <!-- Global Confirm Dialog -->
    <div id="admin-confirm-dialog" class="admin-dialog">
      <div class="admin-dialog-backdrop"></div>
      <div class="admin-dialog-panel">
        <div class="admin-dialog-header">
          <h3 class="admin-dialog-title">确认</h3>
          <button type="button" id="admin-dialog-close" class="admin-dialog-close" aria-label="关闭">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div class="admin-dialog-body" id="admin-dialog-message"></div>
        <div class="admin-dialog-footer">
          <button type="button" id="admin-dialog-cancel" class="btn-dialog btn-dialog-secondary">取消</button>
          <button type="button" id="admin-dialog-confirm" class="btn-dialog btn-dialog-primary">确认</button>
        </div>
      </div>
    </div>

    <div class="admin-shell admin-shell--hidden">
      <!-- Sidebar -->
      <aside class="admin-sidebar">
        <div class="admin-sidebar-header">
          <a href="/" class="admin-logo">子衿</a>
          <span class="admin-badge">管理后台</span>
        </div>
        <nav class="admin-nav" data-current={current}>
          <div class="nav-pill" aria-hidden="true"></div>
          {
            navItems.map((item) => {
              const isActive = current === item.id;
              return (
                <a
                  href={item.href}
                  class={`admin-nav-link ${isActive ? "is-active" : ""}`}
                  data-prefetch
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
        <div class="admin-sidebar-footer">
          <button id="admin-logout" class="admin-logout-btn" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
            退出登录
          </button>
          <a href="/" class="admin-back-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            返回网站
          </a>
        </div>
      </aside>

      <!-- Main -->
      <main class="admin-main" data-admin-module={current}>
        <slot />
      </main>
    </div>

    <script>
      import { initAdminAnimations } from "../scripts/admin-animations";

      const adminRuntime = window as Window & {
        __adminLayoutReady?: boolean;
        __adminLayoutAbort?: AbortController;
      };

      function revealShell(doc: Document = document) {
        const shell = doc.querySelector(".admin-shell");
        if (shell) shell.classList.remove("admin-shell--hidden");
      }

      // ===== Global Glass Confirm Dialog =====
      function showConfirmDialog(message: string, options?: { title?: string; confirmText?: string; cancelText?: string }): Promise<boolean> {
        return new Promise((resolve) => {
          const dialog = document.getElementById("admin-confirm-dialog");
          const msgEl = document.getElementById("admin-dialog-message");
          const titleEl = document.querySelector(".admin-dialog-title") as HTMLElement | null;
          const confirmBtn = document.getElementById("admin-dialog-confirm");
          const cancelBtn = document.getElementById("admin-dialog-cancel");
          const closeBtn = document.getElementById("admin-dialog-close");

          if (!dialog) { resolve(false); return; }

          if (msgEl) msgEl.textContent = message;
          if (titleEl) titleEl.textContent = options?.title || "确认";
          if (confirmBtn) confirmBtn.textContent = options?.confirmText || "确认";
          if (cancelBtn) cancelBtn.textContent = options?.cancelText || "取消";

          dialog.classList.add("is-open");
          document.body.style.overflow = "hidden";

          function cleanup() {
            dialog.classList.remove("is-open");
            document.body.style.overflow = "";
            confirmBtn?.removeEventListener("click", onConfirm);
            cancelBtn?.removeEventListener("click", onCancel);
            closeBtn?.removeEventListener("click", onCancel);
            dialog.removeEventListener("click", onBackdrop);
          }

          function onConfirm() { cleanup(); resolve(true); }
          function onCancel() { cleanup(); resolve(false); }
          function onBackdrop(e: MouseEvent) {
            if (e.target === dialog || (e.target as HTMLElement)?.classList?.contains("admin-dialog-backdrop")) onCancel();
          }

          confirmBtn?.addEventListener("click", onConfirm);
          cancelBtn?.addEventListener("click", onCancel);
          closeBtn?.addEventListener("click", onCancel);
          dialog.addEventListener("click", onBackdrop);
        });
      }
      (window as any).showConfirmDialog = showConfirmDialog;

      function setupAdminPage() {
        // Show shell immediately (auth check already done in <head>)
        revealShell();

        adminRuntime.__adminLayoutAbort?.abort();
        const controller = new AbortController();
        adminRuntime.__adminLayoutAbort = controller;

        // Logout handler
        const logoutBtn = document.getElementById("admin-logout");
        logoutBtn?.addEventListener("click", async function() {
          if (await showConfirmDialog("确定要退出登录吗？")) {
            localStorage.removeItem("admin-auth");
            localStorage.removeItem("admin-auth-time");
            window.location.replace("/admin/login");
          }
        }, { signal: controller.signal });

        // Init animations
        initAdminAnimations();
      }

      // First load
      setupAdminPage();
      if (!adminRuntime.__adminLayoutReady) {
        adminRuntime.__adminLayoutReady = true;
        // Before swap: ensure incoming shell is visible immediately (no opacity:0 flash)
        document.addEventListener("astro:before-swap", (e) => {
          const newDoc = (e as CustomEvent).detail?.newDocument as Document | undefined;
          if (newDoc) revealShell(newDoc);
        });
        // After swap: re-bind events and animations
        document.addEventListener("astro:after-swap", setupAdminPage);
      }
    </script>
  </body>
</html>

<style>
  .admin-body {
    margin: 0;
    padding: 0;
    background: #f4f6fa;
    font-family: var(--font-body);
    color: #181c23;
    min-height: 100vh;
  }
  .admin-shell {
    display: flex;
    min-height: 100vh;
    --admin-ease-out: cubic-bezier(0.23, 1, 0.32, 1);
    --admin-ease-in-out: cubic-bezier(0.77, 0, 0.175, 1);
    --admin-duration-fast: 120ms;
    --admin-duration-standard: 180ms;
  }
  .admin-shell--hidden {
    opacity: 0;
  }
  /* Override Astro's default fade keyframes with slide-enhanced version */
  @keyframes astroFadeOut {
    from { opacity: 1; transform: translateY(0); }
    to { opacity: 0; transform: translateY(-2px); }
  }
  @keyframes astroFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    @keyframes astroFadeOut {
      from { opacity: 1; }
      to { opacity: 0; }
    }
    @keyframes astroFadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
  }
  .admin-sidebar {
    width: 220px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(40px);
    border-right: 1px solid rgba(193,198,214,0.4);
    display: flex;
    flex-direction: column;
    padding: 24px 0;
    position: sticky;
    top: 0;
    height: 100vh;
  }
  .admin-sidebar-header {
    padding: 0 20px 24px;
    border-bottom: 1px solid rgba(193,198,214,0.3);
    margin-bottom: 12px;
  }
  .admin-logo {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: #181c23;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .admin-badge {
    display: inline-block;
    margin-top: 6px;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(0,89,181,0.08);
    color: #0059b5;
    font-size: 12px;
    font-weight: 500;
  }
  .admin-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0 12px;
    flex: 1;
    position: relative;
  }
  .nav-pill {
    position: absolute;
    left: 12px;
    right: 12px;
    border-radius: 10px;
    background: rgba(0,89,181,0.08);
    box-shadow: inset 0 0 0 1px rgba(0,89,181,0.05), 0 4px 16px rgba(0,89,181,0.08);
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transform: translate3d(0, 0, 0);
    transform-origin: 50% 50%;
    backface-visibility: hidden;
    will-change: transform, opacity;
  }
  .admin-nav-link {
    display: flex;
    align-items: center;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 500;
    color: #414753;
    text-decoration: none;
    position: relative;
    z-index: 1;
    transition:
      color var(--admin-duration-standard) var(--admin-ease-out),
      transform var(--admin-duration-fast) var(--admin-ease-out);
    transform: scale(1);
    transform-origin: 50% 50%;
  }
  @media (hover: hover) and (pointer: fine) {
    .admin-nav-link:hover {
      color: #181c23;
    }
  }
  .admin-nav-link.is-active {
    color: #0059b5;
  }
  .admin-nav-link:active {
    transform: scale(0.97);
  }
  .admin-sidebar-footer {
    padding: 16px 20px 0;
    border-top: 1px solid rgba(193,198,214,0.3);
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .admin-logout-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: #717785;
    cursor: pointer;
    transition:
      color var(--admin-duration-standard) var(--admin-ease-out),
      transform var(--admin-duration-fast) var(--admin-ease-out);
    transform: scale(1);
  }
  .admin-logout-btn:hover {
    color: #b91c1c;
  }
  .admin-logout-btn:active {
    transform: scale(0.97);
  }
  .admin-back-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    color: #717785;
    text-decoration: none;
    transition:
      color var(--admin-duration-standard) var(--admin-ease-out),
      transform var(--admin-duration-fast) var(--admin-ease-out);
    transform: scale(1);
  }
  .admin-back-link:hover {
    color: #181c23;
  }
  .admin-back-link:active {
    transform: scale(0.97);
  }
  .admin-main {
    flex: 1;
    padding: 32px 40px;
    overflow-y: auto;
    contain: inline-size;
  }
  :global(.admin-main > .form-section),
  :global(.admin-main > .admin-card),
  :global(.admin-main .project-card),
  :global(.admin-main .article-card),
  :global(.admin-main .gallery-card) {
    content-visibility: auto;
    contain-intrinsic-size: auto 220px;
  }
  :global(.markdown-renderer) {
    display: grid;
    gap: 10px;
  }
  :global(.markdown-renderer-tabs) {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 3px;
    border: 1px solid rgba(193,198,214,0.5);
    border-radius: 10px;
    background: rgba(244,246,250,0.8);
  }
  :global(.markdown-renderer-tab) {
    min-height: 30px;
    padding: 5px 14px;
    border: none;
    border-radius: 7px;
    background: transparent;
    color: #414753;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition:
      background-color var(--admin-duration-fast) var(--admin-ease-out),
      color var(--admin-duration-fast) var(--admin-ease-out);
  }
  :global(.markdown-renderer-tab.is-active) {
    background: #fff;
    color: #0059b5;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  :global(.markdown-renderer-pane[hidden]) {
    display: none;
  }
  :global(.markdown-renderer-preview) {
    min-height: 220px;
    max-height: 520px;
    overflow: auto;
    box-sizing: border-box;
    padding: 16px 18px;
    border: 1px solid rgba(193,198,214,0.5);
    border-radius: 12px;
    background: rgba(255,255,255,0.76);
    color: #181c23;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.7;
  }
  :global(.markdown-renderer-preview > *:first-child) {
    margin-top: 0;
  }
  :global(.markdown-renderer-preview > *:last-child) {
    margin-bottom: 0;
  }
  :global(.markdown-renderer-preview h1),
  :global(.markdown-renderer-preview h2),
  :global(.markdown-renderer-preview h3),
  :global(.markdown-renderer-preview h4) {
    margin: 1.2em 0 0.45em;
    color: #181c23;
    font-family: var(--font-display);
    font-weight: 650;
    line-height: 1.25;
    letter-spacing: 0;
  }
  :global(.markdown-renderer-preview h1) {
    font-size: 24px;
  }
  :global(.markdown-renderer-preview h2) {
    font-size: 20px;
  }
  :global(.markdown-renderer-preview h3) {
    font-size: 17px;
  }
  :global(.markdown-renderer-preview h4) {
    font-size: 15px;
  }
  :global(.markdown-renderer-preview p),
  :global(.markdown-renderer-preview ul),
  :global(.markdown-renderer-preview ol),
  :global(.markdown-renderer-preview blockquote),
  :global(.markdown-renderer-preview pre),
  :global(.markdown-renderer-preview figure),
  :global(.markdown-renderer-preview table) {
    margin: 0 0 14px;
  }
  :global(.markdown-renderer-preview ul),
  :global(.markdown-renderer-preview ol) {
    padding-left: 22px;
  }
  :global(.markdown-renderer-preview li + li) {
    margin-top: 4px;
  }
  :global(.markdown-renderer-preview a) {
    color: #0059b5;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  :global(.markdown-renderer-preview blockquote) {
    padding: 10px 14px;
    border-left: 3px solid #0059b5;
    border-radius: 8px;
    background: rgba(0,89,181,0.06);
    color: #414753;
  }
  :global(.markdown-renderer-preview code) {
    padding: 2px 5px;
    border-radius: 5px;
    background: rgba(0,0,0,0.06);
    font-family: var(--font-mono);
    font-size: 0.92em;
  }
  :global(.markdown-renderer-preview pre) {
    padding: 14px;
    overflow: auto;
    border-radius: 10px;
    background: #181c23;
    color: #f8fafc;
  }
  :global(.markdown-renderer-preview pre code) {
    padding: 0;
    background: transparent;
    color: inherit;
  }
  :global(.markdown-renderer-preview img) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: 10px;
  }
  :global(.markdown-table-wrap) {
    max-width: 100%;
    overflow-x: auto;
  }
  :global(.markdown-renderer-preview table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  :global(.markdown-renderer-preview th),
  :global(.markdown-renderer-preview td) {
    padding: 8px 10px;
    border: 1px solid rgba(193,198,214,0.55);
    text-align: left;
    vertical-align: top;
  }
  :global(.markdown-renderer-preview th) {
    background: rgba(244,246,250,0.9);
    font-weight: 600;
  }
  :global(.markdown-preview-empty) {
    color: #717785;
  }
  @media (max-width: 768px) {
    .admin-sidebar {
      display: none;
    }
    .admin-main {
      padding: 24px;
    }
  }

  /* ===== Global Glass Confirm Dialog ===== */
  .admin-dialog {
    position: fixed;
    inset: 0;
    z-index: 3000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .admin-dialog.is-open {
    display: flex;
  }
  .admin-dialog-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    transition: opacity 0.25s cubic-bezier(0.23, 1, 0.32, 1);
  }
  .admin-dialog.is-open .admin-dialog-backdrop {
    opacity: 1;
  }
  .admin-dialog-panel {
    position: relative;
    background: rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 20px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.4);
    width: 100%;
    max-width: 420px;
    overflow: hidden;
    transform: scale(0.92) translateY(12px);
    opacity: 0;
    transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1), opacity 0.3s cubic-bezier(0.23, 1, 0.32, 1);
    will-change: transform, opacity;
  }
  .admin-dialog.is-open .admin-dialog-panel {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
  .admin-dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px 10px;
  }
  .admin-dialog-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: #181c23;
    margin: 0;
  }
  .admin-dialog-close {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    background: rgba(0, 0, 0, 0.05);
    color: #717785;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .admin-dialog-close:hover {
    background: rgba(0, 0, 0, 0.1);
    color: #181c23;
  }
  .admin-dialog-body {
    padding: 8px 22px 18px;
    font-size: 14px;
    line-height: 1.6;
    color: #414753;
    white-space: pre-line;
  }
  .admin-dialog-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 14px 22px 18px;
    border-top: 1px solid rgba(193, 198, 214, 0.35);
    background: rgba(244, 246, 250, 0.45);
  }
  .btn-dialog {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 9px 18px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s cubic-bezier(0.23, 1, 0.32, 1);
    min-height: 36px;
    border: 1px solid transparent;
  }
  .btn-dialog-secondary {
    background: rgba(255, 255, 255, 0.7);
    color: #414753;
    border-color: rgba(193, 198, 214, 0.5);
  }
  .btn-dialog-secondary:hover {
    background: #fff;
    border-color: rgba(193, 198, 214, 0.8);
    color: #181c23;
  }
  .btn-dialog-primary {
    background: #0059b5;
    color: #fff;
    border-color: #0059b5;
  }
  .btn-dialog-primary:hover {
    background: #004a94;
    border-color: #004a94;
  }
  .btn-dialog:active {
    transform: scale(0.97);
  }
  @media (max-width: 480px) {
    .admin-dialog-panel {
      border-radius: 16px;
    }
    .admin-dialog-footer {
      flex-direction: column-reverse;
    }
    .btn-dialog {
      width: 100%;
    }
  }
</style>
