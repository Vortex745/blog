---
import "../styles/globals.css";
import { getCollection } from "astro:content";
import SEO from "../components/astro/SEO.astro";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
  canonical?: string;
}

const { title, description, image, url, type, publishedTime, tags, canonical } = Astro.props;

const [articles, projects] = await Promise.all([
  getCollection("articles"),
  getCollection("projects"),
]);

const cleanSlug = (id: string) => id.replace(/\.mdx?$/,"");

const searchArticles = articles.map((a) => ({
  id: cleanSlug(a.id),
  title: a.data.title,
  description: a.data.description,
  tags: a.data.tags,
}));

const searchProjects = projects.map((p) => ({
  id: cleanSlug(p.id),
  title: p.data.title,
  description: p.data.description,
  tags: p.data.tags,
}));

const navLinks = [
  { href: "/", label: "首页" },
  { href: "/projects", label: "项目" },
  { href: "/articles", label: "文章" },
  { href: "/gallery", label: "图库" },
  { href: "/archive", label: "归档" },
  { href: "/about", label: "关于" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <link rel="alternate" type="application/rss+xml" title="子衿的个人博客网站" href="/rss.xml" />
    <SEO
      title={title}
      description={description ?? "子衿的个人博客网站"}
      image={image}
      url={url}
      type={type}
      publishedTime={publishedTime}
      tags={tags}
      canonical={canonical}
    />
    <!-- Dark mode initializer — prevents FOUC -->
    <script>
      (function () {
        const theme = localStorage.getItem("theme");
        if (theme === "dark" || (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="editorial-body" lang="zh-CN">
    <!-- Navigation -->
    <nav class="editorial-nav">
      <div class="editorial-nav-inner">
        <!-- Logo -->
        <a href="/" class="editorial-logo" aria-label="子衿的个人博客网站">
          <img src="/logo.jpg" alt="子衿的个人博客网站" class="editorial-logo-img" />
        </a>

        <!-- Desktop nav links with jelly pill -->
        <ul class="editorial-nav-links" id="desktop-nav">
          {
            navLinks.map((link, idx) => {
              const isActive = currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href));
              return (
                <li>
                  <a
                    href={link.href}
                    class={`editorial-nav-link ${isActive ? "is-active" : ""}`}
                    data-index={idx}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })
          }
          <!-- Jelly sliding pill -->
          <li class="nav-pill" id="nav-pill" aria-hidden="true"></li>
        </ul>

        <!-- Right actions -->
        <div class="editorial-nav-actions">
          <!-- Search input -->
          <form class="nav-search-form" action="/search" method="get" role="search">
            <div class="nav-search-group">
              <input
                type="text"
                name="q"
                class="nav-search-input"
                placeholder="搜索…"
                aria-label="搜索内容"
              />
              <div class="nav-search-addon">
                <button type="submit" class="nav-search-icon-btn" aria-label="搜索">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                  </svg>
                </button>
              </div>
            </div>
          </form>

          <!-- Mobile menu toggle -->
          <button id="menu-toggle" class="editorial-icon-btn md:hidden" aria-label="打开菜单" aria-expanded="false">
            <span class="t-icon-swap" data-state="a" aria-hidden="true">
              <span class="t-icon" data-icon="a">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <rect x="2" y="5" width="14" height="1.5" rx="0.75" fill="currentColor" />
                  <rect x="2" y="11" width="14" height="1.5" rx="0.75" fill="currentColor" />
                </svg>
              </span>
              <span class="t-icon" data-icon="b">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M4 4L14 14M14 4L4 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </span>
            </span>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
      <div class="mobile-menu__content t-panel-slide" data-open="false">
        {
          navLinks.map((link) => (
            <a href={link.href} class="mobile-menu__link">
              {link.label}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Main content -->
    <main class="editorial-main">
      <slot />
    </main>

    <!-- GSAP Animation System -->
    <script>
      import { initAnimations, initDockPill } from "../scripts/animations";
      import { initAdminContentSync } from "../scripts/admin-content-sync";

      function boot() {
        initAdminContentSync();
        initAnimations();
        initDockPill();
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot);
      } else {
        boot();
      }
    </script>

    <!-- Scripts -->
    <script>
      // Mobile menu
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");

      if (toggle && menu) {
        const menuPanel = menu.querySelector(".mobile-menu__content");
        const iconSwap = toggle.querySelector(".t-icon-swap");

        function setMenuOpen(open) {
          menu.classList.toggle("is-open", open);
          menu.setAttribute("aria-hidden", String(!open));
          menuPanel?.setAttribute("data-open", String(open));
          toggle.setAttribute("aria-expanded", String(open));
          toggle.setAttribute("aria-label", open ? "关闭菜单" : "打开菜单");
          iconSwap?.setAttribute("data-state", open ? "b" : "a");
        }

        toggle.addEventListener("click", () => {
          const isOpen = menu.classList.contains("is-open");
          setMenuOpen(!isOpen);
        });

        menu.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            setMenuOpen(false);
          });
        });
      }
    </script>

    <style>
      /* Body */
      .editorial-body {
        background-color: #f9f9ff;
        color: #181c23;
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow-x: hidden;
      }

      .editorial-body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -1;
        background-color: #f9f9ff;
        background-image:
          radial-gradient(at 40% 20%, hsla(210,100%,95%,1) 0px, transparent 50%),
          radial-gradient(at 80% 0%, hsla(220,100%,90%,1) 0px, transparent 50%),
          radial-gradient(at 0% 50%, hsla(215,100%,95%,1) 0px, transparent 50%);
        pointer-events: none;
      }

      /* Navigation */
      .editorial-nav {
        position: sticky;
        top: 12px;
        left: 0;
        right: 0;
        z-index: 50;
        margin: 0 auto;
        max-width: fit-content;
        padding: 0 12px;
      }

      .editorial-nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 56px;
        padding: 0 20px;
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(32px);
        -webkit-backdrop-filter: blur(32px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 9999px;
        box-shadow: 0 4px 30px rgba(0, 0, 0, 0.06);
      }

      .editorial-logo {
        display: flex;
        align-items: center;
        margin-right: 24px;
        text-decoration: none;
      }

      .editorial-logo-img {
        height: 32px;
        width: auto;
        border-radius: 8px;
        object-fit: contain;
      }

      .editorial-nav-links {
        display: none;
        align-items: center;
        gap: 4px;
        list-style: none;
        margin: 0;
        padding: 0;
        position: relative;
      }

      @media (min-width: 768px) {
        .editorial-nav-links {
          display: flex;
        }
      }

      .editorial-nav-link {
        position: relative;
        z-index: 2;
        font-family: var(--font-body);
        font-size: 14px;
        font-weight: 500;
        color: #717785;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 9999px;
        transition: color 0.3s cubic-bezier(0.23, 1, 0.32, 1);
        white-space: nowrap;
      }

      @media (hover: hover) and (pointer: fine) {
        .editorial-nav-link:hover {
          color: #181c23;
        }
      }

      .editorial-nav-link.is-active {
        color: #0059b5;
      }

      /* Sliding pill indicator — animated by GSAP (compositor-only: x/y/scaleX/scaleY/opacity) */
      .nav-pill {
        position: absolute;
        top: 0;
        left: 0;
        z-index: 1;
        pointer-events: none;
        background: rgba(0, 89, 181, 0.10);
        border-radius: 9999px;
        opacity: 0;
        will-change: transform;
      }

      .editorial-nav-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-left: 16px;
      }

      /* Search Form in Nav - InputGroup pattern */
      .nav-search-form {
        display: none;
        align-items: center;
        width: 180px;
      }

      @media (min-width: 768px) {
        .nav-search-form {
          display: flex;
        }
      }

      .nav-search-group {
        display: flex;
        align-items: center;
        width: 100%;
        border-radius: 9999px;
        border: 1px solid rgba(193, 198, 214, 0.5);
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(16px);
        transition:
          border-color var(--motion-duration-standard) var(--motion-ease-out),
          box-shadow var(--motion-duration-standard) var(--motion-ease-out),
          background-color var(--motion-duration-standard) var(--motion-ease-out);
        overflow: hidden;
      }

      .nav-search-group:focus-within {
        border-color: #0059b5;
        box-shadow: 0 0 0 3px rgba(0, 89, 181, 0.1);
        background: rgba(255, 255, 255, 0.82);
      }

      .nav-search-input {
        flex: 1;
        min-width: 0;
        height: 34px;
        padding: 0 0 0 14px;
        border: none;
        background: transparent;
        font-family: var(--font-body);
        font-size: 13px;
        color: #181c23;
        outline: none;
      }

      .nav-search-input::placeholder {
        color: #717785;
      }

      .nav-search-addon {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        flex-shrink: 0;
      }

      .nav-search-icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: none;
        background: transparent;
        color: #717785;
        cursor: pointer;
        transition: color 0.2s ease, background-color 0.2s ease;
      }

      @media (hover: hover) and (pointer: fine) {
        .nav-search-icon-btn:hover {
          color: #0059b5;
          background-color: rgba(0, 89, 181, 0.06);
        }
      }

      /* Mobile search */
      .mobile-search-form {
        display: flex;
        width: 100%;
        padding: 0 24px 16px;
      }

      .mobile-search-input {
        flex: 1;
        height: 44px;
        padding: 0 16px;
        border-radius: 12px;
        border: 1px solid rgba(193, 198, 214, 0.5);
        background: rgba(255, 255, 255, 0.8);
        font-family: var(--font-body);
        font-size: 16px;
        color: #181c23;
        outline: none;
      }

      .editorial-icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        color: #717785;
        background: transparent;
        border: none;
        cursor: pointer;
        transition: color 0.2s cubic-bezier(0.23, 1, 0.32, 1), background-color 0.2s cubic-bezier(0.23, 1, 0.32, 1), transform 0.15s cubic-bezier(0.23, 1, 0.32, 1);
        transform: scale(1);
      }

      @media (hover: hover) and (pointer: fine) {
        .editorial-icon-btn:hover {
          color: #181c23;
          background-color: rgba(0, 0, 0, 0.04);
        }
      }

      .editorial-icon-btn:active {
        transform: scale(0.92);
      }

      .editorial-icon-btn .t-icon {
        display: grid;
        place-items: center;
      }

      /* Mobile menu */
      .mobile-menu {
        position: fixed;
        inset: 0;
        z-index: 40;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        opacity: 0;
        pointer-events: none;
        visibility: hidden;
        transition: opacity 160ms cubic-bezier(0.23, 1, 0.32, 1), visibility 0s linear 160ms;
      }

      .mobile-menu.is-open {
        opacity: 1;
        pointer-events: auto;
        visibility: visible;
        transition: opacity 160ms cubic-bezier(0.23, 1, 0.32, 1), visibility 0s linear 0s;
      }

      .mobile-menu__content {
        --panel-open-dur: 260ms;
        --panel-close-dur: 180ms;
        --panel-translate-y: 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        gap: 32px;
      }

      .mobile-menu__link {
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 600;
        color: #181c23;
        text-decoration: none;
        opacity: 0.88;
        transform: scale(1);
        transition: opacity 160ms cubic-bezier(0.23, 1, 0.32, 1), transform 120ms cubic-bezier(0.23, 1, 0.32, 1);
      }

      @media (hover: hover) and (pointer: fine) {
        .mobile-menu__link:hover {
          opacity: 0.6;
        }
      }

      .mobile-menu__link:active {
        transform: scale(0.96);
      }

      /* Main */
      .editorial-main {
        flex: 1;
      }

    </style>
  </body>
</html>
